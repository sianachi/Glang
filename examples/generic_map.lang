// Demonstrates a generic Map<K, V> plus Stack<T> and Queue<T> working together.
// The stock lookup lives in a `shop` namespace: present items report their
// count, missing items report -1.
// Run: python3 main.py run examples/generic_map.lang

import "std/map.lang";
import "std/stack.lang";
import "std/queue.lang";

namespace shop {

int stockOf(Map<string, int> inv, string item) {
    return inv.getOr(item, -1);
}

}

int main() {
    Map<string, int> inventory = Map<string, int>();
    inventory.set("apples", 5);
    inventory.set("pears", 2);
    inventory.set("apples", 8);     // overwrite
    print(inventory.length());      // 2
    print(shop::stockOf(inventory, "apples")); // 8
    print(shop::stockOf(inventory, "kiwis"));  // -1
    print(inventory.has("pears"));  // true
    inventory.remove("pears");
    print(inventory.has("pears"));  // false

    Stack<int> st = Stack<int>();
    for (int i = 1; i <= 4; ++i) { st.push(i); }
    print(st.pop());                // 4
    print(st.pop());                // 3
    print(st.length());             // 2

    Queue<int> q = Queue<int>();
    for (int i = 1; i <= 4; ++i) { q.enqueue(i); }
    print(q.dequeue());             // 1
    print(q.dequeue());             // 2
    print(q.length());              // 2
    return 0;
}
