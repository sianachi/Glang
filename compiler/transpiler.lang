// compiler/transpiler.lang
// Glang → C transpiler written in Glang (dogfooding).
//
// Usage (via main.py compile):
//   python3 main.py run compiler/transpiler.lang <ast_file> <output.c>
//
// The ast_file is the indented tagged-line serialisation produced by
// compiler/ast_serializer.py after the full Glang analysis pipeline.

import "std/list.lang";
import "std/map.lang";
import "std/stringbuilder.lang";
import "std/string.lang";

// ═══════════════════════════════════════════════════════════════════════════
// AstNode — generic tree node (tag + string attrs + child list)
// ═══════════════════════════════════════════════════════════════════════════

class AstNode {
    string tag;
    Map<string, string> attrs;
    List<AstNode*> children;

    AstNode(string t) {
        this.tag = t;
        this.attrs = Map<string, string>();
        this.children = List<AstNode*>();
    }

    string get(string key) {
        return this.attrs.getOr(key, "");
    }

    bool has(string key) {
        return this.attrs.has(key);
    }

    bool getBool(string key) {
        return this.get(key) == "true";
    }

    int getInt(string key) {
        return parseInt(this.get(key));
    }

    AstNode* child(int i) {
        return this.children.get(i);
    }

    int numChildren() {
        return this.children.length();
    }
}

// ═══════════════════════════════════════════════════════════════════════════
// Utility helpers
// ═══════════════════════════════════════════════════════════════════════════

int hexDigitVal(char c) {
    if ((int)c >= (int)'0' && (int)c <= (int)'9') { return (int)c - (int)'0'; }
    if ((int)c >= (int)'a' && (int)c <= (int)'f') { return (int)c - (int)'a' + 10; }
    if ((int)c >= (int)'A' && (int)c <= (int)'F') { return (int)c - (int)'A' + 10; }
    return 0;
}

string decodeVal(string s) {
    StringBuilder sb = StringBuilder();
    int i = 0;
    int n = len(s);
    while (i < n) {
        if (s[i] == '%' && i + 2 < n) {
            int code = hexDigitVal(s[i+1]) * 16 + hexDigitVal(s[i+2]);
            sb.appendChar((char)code);
            i = i + 3;
        } else {
            sb.appendChar(s[i]);
            i = i + 1;
        }
    }
    return sb.build();
}

int countLeadingSpaces(string line) {
    int i = 0;
    int n = len(line);
    while (i < n && line[i] == ' ') {
        i = i + 1;
    }
    return i;
}

// Mangle a Glang type name to a valid C identifier.
// "List<int>" → "List_int", "Map<string,int>" → "Map_string_int", "::" → "__"
string mangleName(string s) {
    StringBuilder sb = StringBuilder();
    int n = len(s);
    int i = 0;
    while (i < n) {
        char c = s[i];
        if (c == '<') {
            sb.appendChar('_');
        } else if (c == '>') {
            // skip
        } else if (c == ',') {
            sb.appendChar('_');
        } else if (c == ' ') {
            // skip
        } else if (c == ':' && i + 1 < n && s[i+1] == ':') {
            sb.append("__");
            i = i + 2;
            continue;
        } else if (c == '*' || c == '?' || c == '[' || c == ']') {
            // these shouldn't appear in names
        } else {
            sb.appendChar(c);
        }
        i = i + 1;
    }
    return sb.build();
}

// Convert a Glang type string to C type string.
string cTypeOf(string t) {
    if (t == "int")    { return "int64_t"; }
    if (t == "float")  { return "double"; }
    if (t == "bool")   { return "int"; }
    if (t == "char")   { return "char"; }
    if (t == "byte")   { return "uint8_t"; }
    if (t == "string") { return "char*"; }
    if (t == "void")   { return "void"; }
    if (t == "null")   { return "void*"; }
    // Function pointer: "fn(T,...)->R" — represented as GlangFn { void* fn; void* cap; }.
    // Checked before the "*" case because the return type R may end in '*'
    // (e.g. fn()->Stmt*), which must not be mistaken for a pointer-to-fn.
    if (startsWith(t, "fn(")) { return "GlangFn"; }
    // Pointer: "T*"
    if (endsWith(t, "*")) {
        string base = substr(t, 0, len(t) - 1);
        return cTypeOf(base) + "*";
    }
    // Nullable: "T?" — emit as the inner type (value with has_val field is complex, skip for MVP)
    if (endsWith(t, "?")) {
        return cTypeOf(substr(t, 0, len(t) - 1));
    }
    // Array: "T[N]" — in declarations we need "T varname[N]", handled by cTypeDecl
    if (endsWith(t, "]")) {
        int lb = strings::indexOf(t, '[');
        if (lb >= 0) {
            return cTypeOf(substr(t, 0, lb));
        }
    }
    // Class / enum / union / generic
    return mangleName(t);
}

// Produce "C_type varname" or "C_type varname[N]" for array types.
string cTypeDecl(string t, string varName) {
    if (endsWith(t, "]")) {
        int lb = strings::indexOf(t, '[');
        if (lb >= 0) {
            string base = substr(t, 0, lb);
            string size = substr(t, lb + 1, len(t) - 1);
            return cTypeOf(base) + " " + varName + "[" + size + "]";
        }
    }
    return cTypeOf(t) + " " + varName;
}

// Parse "fn(T1,T2,...)->R" into its params substring and ret type.
// Returns "" if not a fn type. Stores results into the two out params by
// encoding as "PARAMS|RET" and returning that string.
// Simple heuristic: find first ")->" to split (works when params have no nested fn types).
string parseFnType(string fnType) {
    // Check if starts with "fn("
    if (len(fnType) < 3) { return ""; }
    if (substr(fnType, 0, 3) != "fn(") { return ""; }
    // Find the first ')' which closes the param list, then skip "->"
    int closePos = strings::indexOf(fnType, ')');
    if (closePos < 0) { return ""; }
    string paramsStr = substr(fnType, 3, closePos);            // between "fn(" and ")"
    string retStr    = substr(fnType, closePos + 3, len(fnType)); // after ")->"
    return paramsStr + "|" + retStr;
}

// Emit a call through a GlangFn variable.
// fnType = "fn(int,int)->int", varName = "op", argStrs = ["40", "2"]
// Returns: "((int64_t(*)(void*,int64_t,int64_t))op.fn)(op.cap, 40, 2)"
string emitGlangFnCall(string varName, string fnType, List<string> argStrs) {
    string parts = parseFnType(fnType);
    string retStr = "int";
    string paramsStr = "";
    if (len(parts) > 0) {
        int pipe = strings::indexOf(parts, '|');
        if (pipe >= 0) {
            paramsStr = substr(parts, 0, pipe);
            retStr    = substr(parts, pipe + 1, len(parts));
        }
    }
    string cRet = cTypeOf(retStr);
    // Build cast type: "(RetType(*)(void*, param types...))"
    StringBuilder castSB = StringBuilder();
    castSB.append(cRet + "(*)(void*");
    if (len(paramsStr) > 0) {
        List<string> ptypes = strings::split(paramsStr, ',');
        for (int i = 0; i < ptypes.length(); ++i) {
            castSB.append(", " + cTypeOf(ptypes.get(i)));
        }
    }
    castSB.append(")");
    string capArg = varName + ".cap";
    StringBuilder callSB = StringBuilder();
    callSB.append("((" + castSB.build() + ")" + varName + ".fn)(" + capArg);
    for (int i = 0; i < argStrs.length(); ++i) {
        callSB.append(", " + argStrs.get(i));
    }
    callSB.append(")");
    return callSB.build();
}

// Wrap a free function name as a GlangFn value: { (void*)fname, NULL }
string wrapFreeFunction(string cFuncName) {
    return "((GlangFn){ (void*)" + cFuncName + ", NULL })";
}

// ═══════════════════════════════════════════════════════════════════════════
// AstReader — builds tree from serialised tagged-line format
// ═══════════════════════════════════════════════════════════════════════════

class AstReader {
    List<string> lines;
    int pos;

    AstReader(List<string> lines) {
        this.lines = lines;
        this.pos = 0;
    }

    // Skip blank lines; returns -1 if no more lines.
    int peekDepth() {
        while (this.pos < this.lines.length()) {
            string line = this.lines.get(this.pos);
            if (len(line) > 0 && !(this.isBlank(line))) {
                return countLeadingSpaces(line) / 2;
            }
            this.pos = this.pos + 1;
        }
        return -1;
    }

    bool isBlank(string line) {
        int n = len(line);
        for (int i = 0; i < n; ++i) {
            if (line[i] != ' ' && line[i] != '\t' && line[i] != '\r') {
                return false;
            }
        }
        return true;
    }

    // Read one node at expectedDepth, then recursively collect all children
    // at expectedDepth+1.
    AstNode* readNode(int expectedDepth) {
        // Skip blanks
        while (this.pos < this.lines.length() && this.isBlank(this.lines.get(this.pos))) {
            this.pos = this.pos + 1;
        }
        if (this.pos >= this.lines.length()) { return null; }

        string line = this.lines.get(this.pos);
        int depth = countLeadingSpaces(line) / 2;
        if (depth != expectedDepth) { return null; }

        this.pos = this.pos + 1;

        // Strip indent and parse header
        string content = substr(line, expectedDepth * 2, len(line));
        AstNode* node = this.parseHeader(content);

        // Collect children at expectedDepth+1
        while (true) {
            int nextDepth = this.peekDepth();
            if (nextDepth != expectedDepth + 1) {
                break;
            }
            AstNode* child = this.readNode(expectedDepth + 1);
            if (child != null) {
                node.children.add(child);
            }
        }

        return node;
    }

    AstNode* parseHeader(string content) {
        // Split "TAG key1=val1 key2=val2" by spaces
        List<string> parts = strings::split(content, ' ');
        string tag = "";
        if (parts.length() > 0) { tag = parts.get(0); }
        AstNode* node = new AstNode(tag);

        for (int i = 1; i < parts.length(); ++i) {
            string kv = parts.get(i);
            if (len(kv) == 0) { continue; }
            int eq = strings::indexOf(kv, '=');
            if (eq >= 0) {
                string k = substr(kv, 0, eq);
                string v = decodeVal(substr(kv, eq + 1, len(kv)));
                node.attrs.set(k, v);
            }
        }
        return node;
    }
}

// ═══════════════════════════════════════════════════════════════════════════
// GlobalInfo — symbol tables built by scanning all top-level declarations
// ═══════════════════════════════════════════════════════════════════════════

class GlobalInfo {
    Map<string, string> classSuper;        // className → superclass name
    Map<string, string> fieldType;         // "Class.field" → type
    Map<string, string> methodRet;         // "Class.method" → return type
    Map<string, string> funcRet;           // funcName → return type
    Map<string, string> modRet;            // "target.method" → return type
    // Union variant field info: "UnionName.VariantName.N" → "fieldname:type"
    Map<string, string> unionFieldAt;
    // Union variant field count: "UnionName.VariantName" → count
    Map<string, string> unionVariantFields;
    List<string> classNames;
    List<string> enumNames;
    List<string> unionNames;
    List<string> interfaceNames;

    GlobalInfo() {
        this.classSuper    = Map<string, string>();
        this.fieldType     = Map<string, string>();
        this.methodRet     = Map<string, string>();
        this.funcRet       = Map<string, string>();
        this.modRet        = Map<string, string>();
        this.unionFieldAt  = Map<string, string>();
        this.unionVariantFields = Map<string, string>();
        this.classNames    = List<string>();
        this.enumNames     = List<string>();
        this.unionNames    = List<string>();
        this.interfaceNames = List<string>();
    }

    void buildFrom(AstNode* program) {
        int n = program.numChildren();
        for (int i = 0; i < n; ++i) {
            AstNode* decl = program.child(i);
            string tag = decl.tag;
            if (tag == "FUNC") {
                this.funcRet.set(decl.get("name"), decl.get("ret"));
            } else if (tag == "CLASS") {
                string name = decl.get("name");
                this.classNames.add(name);
                this.classSuper.set(name, decl.get("super"));
                for (int j = 0; j < decl.numChildren(); ++j) {
                    AstNode* ch = decl.child(j);
                    if (ch.tag == "FIELD" || ch.tag == "SFIELD") {
                        this.fieldType.set(name + "." + ch.get("name"), ch.get("type"));
                    } else if (ch.tag == "METHOD") {
                        this.methodRet.set(name + "." + ch.get("name"), ch.get("ret"));
                    }
                }
            } else if (tag == "ENUM") {
                this.enumNames.add(decl.get("name"));
            } else if (tag == "UNION") {
                string uname = decl.get("name");
                this.unionNames.add(uname);
                // Store variant field info for ARM binding extraction
                for (int j = 0; j < decl.numChildren(); ++j) {
                    AstNode* variant = decl.child(j);
                    if (variant.tag == "UNION_VARIANT") {
                        string vname = variant.get("name");
                        int nfields = variant.getInt("fields");
                        string vkey = uname + "." + vname;
                        this.unionVariantFields.set(vkey, strings::intToStr(nfields));
                        for (int k = 0; k < variant.numChildren(); ++k) {
                            AstNode* uf = variant.child(k);
                            if (uf.tag == "UNION_FIELD") {
                                string fkey = vkey + "." + strings::intToStr(k);
                                this.unionFieldAt.set(fkey, uf.get("name") + ":" + uf.get("type"));
                            }
                        }
                    }
                }
            } else if (tag == "INTERFACE") {
                this.interfaceNames.add(decl.get("name"));
            } else if (tag == "MODIFIER") {
                string target = decl.get("target");
                for (int j = 0; j < decl.numChildren(); ++j) {
                    AstNode* ch = decl.child(j);
                    if (ch.tag == "METHOD") {
                        this.modRet.set(target + "." + ch.get("name"), ch.get("ret"));
                    }
                }
            }
        }
    }

    bool isClass(string name) {
        return this.classNames.contains(name);
    }

    bool isEnum(string name) {
        return this.enumNames.contains(name);
    }

    bool isUnion(string name) {
        return this.unionNames.contains(name);
    }

    bool isPrimitive(string name) {
        return name == "int" || name == "float" || name == "bool" ||
               name == "char" || name == "byte" || name == "string" || name == "void";
    }

    bool hasModifier(string target, string method) {
        return this.modRet.has(target + "." + method);
    }

    string getMethodRet(string cls, string method) {
        string key = cls + "." + method;
        string r = this.methodRet.getOr(key, "");
        if (r != "") { return r; }
        // walk superclass chain
        string sc = this.classSuper.getOr(cls, "");
        while (sc != "") {
            r = this.methodRet.getOr(sc + "." + method, "");
            if (r != "") { return r; }
            sc = this.classSuper.getOr(sc, "");
        }
        return "";
    }

    // Returns the type of `field` in cls or any ancestor.
    string getFieldType(string cls, string field) {
        string r = this.fieldType.getOr(cls + "." + field, "");
        if (r != "") { return r; }
        string sc = this.classSuper.getOr(cls, "");
        while (sc != "") {
            r = this.fieldType.getOr(sc + "." + field, "");
            if (r != "") { return r; }
            sc = this.classSuper.getOr(sc, "");
        }
        return "";
    }

    // Returns the class (cls or ancestor) that defines `method`.
    string findMethodClass(string cls, string method) {
        string r = this.methodRet.getOr(cls + "." + method, "");
        if (r != "") { return cls; }
        string sc = this.classSuper.getOr(cls, "");
        while (sc != "") {
            r = this.methodRet.getOr(sc + "." + method, "");
            if (r != "") { return sc; }
            sc = this.classSuper.getOr(sc, "");
        }
        return cls; // fallback to cls itself
    }
}

// ═══════════════════════════════════════════════════════════════════════════
// TypeInferencer — best-effort static type of any AST expression node
// ═══════════════════════════════════════════════════════════════════════════

class TypeInferencer {
    GlobalInfo info;
    List<Map<string, string>> scopes;
    string currentClass;

    TypeInferencer(GlobalInfo info) {
        this.info = info;
        this.scopes = List<Map<string, string>>();
        this.currentClass = "";
    }

    void pushScope() {
        this.scopes.add(Map<string, string>());
    }

    void popScope() {
        if (this.scopes.length() > 0) {
            this.scopes.removeAt(this.scopes.length() - 1);
        }
    }

    void define(string name, string type) {
        if (this.scopes.length() > 0) {
            this.scopes.get(this.scopes.length() - 1).set(name, type);
        }
    }

    string lookup(string name) {
        int n = this.scopes.length();
        for (int i = n - 1; i >= 0; --i) {
            string t = this.scopes.get(i).getOr(name, "");
            if (t != "") { return t; }
        }
        return "";
    }

    string infer(AstNode* e) {
        if (e == null) { return "void"; }
        string tag = e.tag;

        if (tag == "LIT")    { return e.get("kind"); }
        if (tag == "NULL")   { return "null"; }
        if (tag == "THIS")   {
            if (this.currentClass != "") { return this.currentClass + "*"; }
            return "void*";
        }
        if (tag == "SUPER")  {
            string sc = this.info.classSuper.getOr(this.currentClass, "");
            if (sc != "") { return sc + "*"; }
            return "void*";
        }
        if (tag == "IDENT") {
            string name = e.get("name");
            string t = this.lookup(name);
            if (t != "") { return t; }
            // Enum type name used as namespace (e.g., "Direction" in "Direction.NORTH")
            if (this.info.isEnum(name)) { return name; }
            // Union type name used as namespace (e.g., "JsonValue" in "JsonValue.Number(42)")
            if (this.info.isUnion(name)) { return name; }
            // Class name used as value
            if (this.info.isClass(name)) { return name + "*"; }
            // Function name used as a value
            t = this.info.funcRet.getOr(name, "");
            if (t != "") { return "fn"; }
            return "int"; // fallback
        }
        if (tag == "BINARY") {
            string op = e.get("op");
            if (op == "==" || op == "!=" || op == "<" || op == "<=" ||
                op == ">" || op == ">=" || op == "&&" || op == "||") {
                return "bool";
            }
            if (op == "??") {
                return this.infer(e.child(0));
            }
            string lt = this.infer(e.child(0));
            string rt = this.infer(e.child(1));
            if (lt == "string" || rt == "string") { return "string"; }
            if (lt == "float"  || rt == "float")  { return "float"; }
            return lt;
        }
        if (tag == "UNARY") {
            string op = e.get("op");
            if (op == "!") { return "bool"; }
            if (op == "~") { return "int"; }
            return this.infer(e.child(0));
        }
        if (tag == "CAST") { return e.get("to"); }
        if (tag == "CALL") {
            string name = e.get("name");
            // Builtins
            if (name == "len" || name == "parseInt" || name == "getArgCount") { return "int"; }
            if (name == "parseFloat") { return "float"; }
            if (name == "startsWith" || name == "endsWith" || name == "contains" || name == "fileExists") { return "bool"; }
            if (name == "toString" || name == "intToStr" || name == "readFile" || name == "readStdin" || name == "getArg" || name == "substr") { return "string"; }
            string r = this.info.funcRet.getOr(name, "");
            if (r != "") { return r; }
            return "int";
        }
        if (tag == "INDIRECT_CALL") { return "int"; }
        if (tag == "METHOD_CALL") {
            string method = e.get("method");
            string objType = this.infer(e.child(0));
            // Strip pointer — both . and -> access uses base class name for lookups
            string baseType = objType;
            if (endsWith(objType, "*")) {
                baseType = substr(objType, 0, len(objType) - 1);
            }
            // Check modifier first
            string r = this.info.modRet.getOr(baseType + "." + method, "");
            if (r != "") { return r; }
            // Then class method (with super chain)
            r = this.info.getMethodRet(baseType, method);
            if (r != "") { return r; }
            return "int";
        }
        if (tag == "NEW")    { return e.get("cls") + "*"; }
        if (tag == "DELETE") { return "void"; }
        if (tag == "ALLOC") {
            string t = e.get("type");
            return t + "*";
        }
        if (tag == "FREE")   { return "void"; }
        if (tag == "FIELD_ACCESS") {
            string objType = this.infer(e.child(0));
            // Strip pointer — emitVarDecl now registers class vars as Class*
            string baseType = objType;
            if (endsWith(objType, "*")) {
                baseType = substr(objType, 0, len(objType) - 1);
            }
            string field = e.get("field");
            string r = this.info.getFieldType(baseType, field);
            if (r != "") { return r; }
            return "int";
        }
        if (tag == "ARROW_ACCESS") {
            string ptrType = this.infer(e.child(0));
            string baseType = ptrType;
            if (endsWith(ptrType, "*")) {
                baseType = substr(ptrType, 0, len(ptrType) - 1);
            }
            string field = e.get("field");
            string r = this.info.getFieldType(baseType, field);
            if (r != "") { return r; }
            return "int";
        }
        if (tag == "INDEX") {
            string arrType = this.infer(e.child(0));
            // "int[10]" → "int"
            if (endsWith(arrType, "]")) {
                int lb = strings::indexOf(arrType, '[');
                if (lb >= 0) { return substr(arrType, 0, lb); }
            }
            // "int*" → "int"
            if (endsWith(arrType, "*")) {
                return substr(arrType, 0, len(arrType) - 1);
            }
            // "string" → "char"
            if (arrType == "string") { return "char"; }
            return "int";
        }
        if (tag == "ADDRESS_OF") {
            return this.infer(e.child(0)) + "*";
        }
        if (tag == "DEREF") {
            string t = this.infer(e.child(0));
            if (endsWith(t, "*")) { return substr(t, 0, len(t) - 1); }
            return t;
        }
        if (tag == "CLOSURE") { return "fn"; }
        return "int"; // fallback
    }
}

// ═══════════════════════════════════════════════════════════════════════════
// CEmitter — walks the AstNode tree and emits C code via StringBuilder
// ═══════════════════════════════════════════════════════════════════════════

class CEmitter {
    StringBuilder out;
    TypeInferencer typer;
    GlobalInfo info;
    int indentLevel;
    int closureCounter;
    int usingCounter;
    string currentRetType;    // return type of current function/method
    StringBuilder preamble;   // forward decls, struct typedefs
    StringBuilder structs;    // struct bodies
    StringBuilder enums;      // enum #defines
    StringBuilder sfields;    // static field globals
    StringBuilder protos;     // function prototypes
    StringBuilder closureDefs; // closure structs/fns emitted before their enclosing fn
    Map<string, string> fnThunks; // cFuncName → thunk name (to avoid duplicate thunks)
    List<string> hierEntries; // class hierarchy pairs for instanceof

    CEmitter(GlobalInfo info) {
        this.out           = StringBuilder();
        this.typer         = TypeInferencer(info);
        this.info          = info;
        this.indentLevel   = 0;
        this.closureCounter = 0;
        this.usingCounter  = 0;
        this.currentRetType = "";
        this.preamble      = StringBuilder();
        this.structs       = StringBuilder();
        this.enums         = StringBuilder();
        this.sfields       = StringBuilder();
        this.protos        = StringBuilder();
        this.closureDefs   = StringBuilder();
        this.fnThunks      = Map<string, string>();
        this.hierEntries   = List<string>();
    }

    // Wrap a free C function as a GlangFn. Emits a thunk that adds the void* cap arg.
    // fnType is the Glang type string like "fn(int,int)->int".
    string makeFnThunk(string cFuncName, string fnType) {
        string existing = this.fnThunks.getOr(cFuncName, "");
        if (existing != "") { return existing; }
        string thunkName = "__thunk_" + cFuncName + "__";
        this.fnThunks.set(cFuncName, thunkName);
        // Parse fn type for signature
        string parts = parseFnType(fnType);
        string retStr = "int64_t";
        string paramsStr = "";
        if (len(parts) > 0) {
            int pipe = strings::indexOf(parts, '|');
            if (pipe >= 0) {
                paramsStr = substr(parts, 0, pipe);
                retStr    = cTypeOf(substr(parts, pipe + 1, len(parts)));
            }
        }
        // Build param list with names p0, p1, ...
        StringBuilder thunkParams = StringBuilder();
        StringBuilder innerArgs   = StringBuilder();
        thunkParams.append("void* __cap__");
        List<string> plist = List<string>();
        if (len(paramsStr) > 0) { plist = strings::split(paramsStr, ','); }
        for (int i = 0; i < plist.length(); ++i) {
            string pname = "p" + strings::intToStr(i);
            thunkParams.append(", " + cTypeDecl(plist.get(i), pname));
            if (i > 0) { innerArgs.append(", "); }
            innerArgs.append(pname);
        }
        this.cdln("static " + retStr + " " + thunkName + "(" + thunkParams.build() + ") {");
        if (retStr == "void") {
            this.cdln("    " + cFuncName + "(" + innerArgs.build() + ");");
        } else {
            this.cdln("    return " + cFuncName + "(" + innerArgs.build() + ");");
        }
        this.cdln("}");
        this.cdln("");
        return thunkName;
    }

    string wrapAsGlangFn(string cFuncName, string fnType) {
        string thunk = this.makeFnThunk(cFuncName, fnType);
        return "((GlangFn){ (void*)" + thunk + ", NULL })";
    }

    // Convert a Glang return type to C, adding * for class types.
    string cRetType(string type) {
        if (this.info.isClass(type)) { return cTypeOf(type) + "*"; }
        return cTypeOf(type);
    }

    string ind() {
        string s = "";
        for (int i = 0; i < this.indentLevel; ++i) { s = s + "    "; }
        return s;
    }

    void ln(string s) {
        this.out.append(this.ind());
        this.out.appendLine(s);
    }

    void raw(string s) {
        this.out.append(s);
    }

    void pln(string s) {
        this.preamble.appendLine(s);
    }

    void sln(string s) {
        this.structs.appendLine(s);
    }

    void eln(string s) {
        this.enums.appendLine(s);
    }

    void sfln(string s) {
        this.sfields.appendLine(s);
    }

    void prln(string s) {
        this.protos.appendLine(s);
    }

    void cdln(string s) {
        this.closureDefs.appendLine(s);
    }

    // ── Collect inherited fields (depth-first, base first) ───────────────

    void collectFields(string className, List<string> nameList, List<string> typeList) {
        string superName = this.info.classSuper.getOr(className, "");
        if (superName != "") {
            this.collectFields(superName, nameList, typeList);
        }
        // add this class's own fields (from preamble scanning is hard; we use the AST)
        // We'll call this from emitClass with the CLASS node directly instead.
    }

    // ── Emit the whole program ───────────────────────────────────────────

    void emitProgram(AstNode* program) {
        // Pass 1: forward typedef declarations + class hierarchy
        int n = program.numChildren();
        for (int i = 0; i < n; ++i) {
            AstNode* decl = program.child(i);
            string tag = decl.tag;
            if (tag == "CLASS") {
                string name = mangleName(decl.get("name"));
                this.pln("typedef struct " + name + " " + name + ";");
                // hierarchy
                string superName = decl.get("super");
                if (superName != "") {
                    this.hierEntries.add(mangleName(decl.get("name")));
                    this.hierEntries.add(mangleName(superName));
                }
            } else if (tag == "UNION") {
                string name = mangleName(decl.get("name"));
                this.pln("typedef struct " + name + " " + name + ";");
            }
        }

        // Pass 2: structs, enums, static fields
        for (int i = 0; i < n; ++i) {
            AstNode* decl = program.child(i);
            string tag = decl.tag;
            if (tag == "CLASS") {
                this.emitClassStructs(decl, program);
            } else if (tag == "ENUM") {
                this.emitEnum(decl);
            } else if (tag == "UNION") {
                this.emitUnionStruct(decl);
            }
        }

        // Pass 3: static field globals
        for (int i = 0; i < n; ++i) {
            AstNode* decl = program.child(i);
            if (decl.tag == "CLASS") {
                this.emitStaticFieldGlobals(decl);
            }
        }

        // Pass 4: function + method prototypes
        for (int i = 0; i < n; ++i) {
            AstNode* decl = program.child(i);
            this.emitPrototype(decl);
        }

        // Pass 5: full function / method / modifier bodies
        for (int i = 0; i < n; ++i) {
            AstNode* decl = program.child(i);
            this.emitDecl(decl);
        }

        // Emit C main wrapper
        this.out.appendLine("");
        this.out.appendLine("/* ── C entry point ─────────────────────────────── */");
        this.out.appendLine("int main(int argc, char** argv) {");
        this.out.appendLine("    glang_argc = argc;");
        this.out.appendLine("    glang_argv = argv;");
        this.out.appendLine("    return (int)glang_main();");
        this.out.appendLine("}");
    }

    // ── Class struct bodies ──────────────────────────────────────────────

    void emitClassStructs(AstNode* cls, AstNode* program) {
        string rawName = cls.get("name");
        string name = mangleName(rawName);
        this.sln("struct " + name + " {");

        // Emit superclass fields first (recursively)
        string superName = cls.get("super");
        if (superName != "") {
            this.emitInheritedFields(superName, program);
        }

        // Own instance fields
        for (int i = 0; i < cls.numChildren(); ++i) {
            AstNode* ch = cls.child(i);
            if (ch.tag == "FIELD") {
                string ftype = ch.get("type");
                string fname = ch.get("name");
                // Class-typed fields use pointer (reference semantics)
                string cftype = ftype;
                if (this.info.isClass(ftype)) { cftype = ftype + "*"; }
                this.sln("    " + cTypeDecl(cftype, mangleName(fname)) + ";");
            }
        }
        this.sln("};");
        this.sln("");
    }

    void emitInheritedFields(string className, AstNode* program) {
        // Find the CLASS node for className and emit its fields
        int n = program.numChildren();
        for (int i = 0; i < n; ++i) {
            AstNode* decl = program.child(i);
            if (decl.tag == "CLASS" && decl.get("name") == className) {
                // Recurse for super
                string superName = decl.get("super");
                if (superName != "") {
                    this.emitInheritedFields(superName, program);
                }
                // Emit fields
                for (int j = 0; j < decl.numChildren(); ++j) {
                    AstNode* ch = decl.child(j);
                    if (ch.tag == "FIELD") {
                        string ftype = ch.get("type");
                        string fname = ch.get("name");
                        if (this.info.isClass(ftype)) { ftype = ftype + "*"; }
                        this.sln("    " + cTypeDecl(ftype, mangleName(fname)) + ";");
                    }
                }
                return;
            }
        }
    }

    void emitStaticFieldGlobals(AstNode* cls) {
        string rawName = cls.get("name");
        string name = mangleName(rawName);
        for (int i = 0; i < cls.numChildren(); ++i) {
            AstNode* ch = cls.child(i);
            if (ch.tag == "SFIELD") {
                string ftype = ch.get("type");
                string fname = ch.get("name");
                // The initializer is the one child of SFIELD
                string initExpr = "0";
                if (ch.numChildren() > 0) {
                    initExpr = this.emitExpr(ch.child(0));
                }
                bool isConst = ch.getBool("const");
                string constPfx = "";
                if (isConst) { constPfx = "const "; }
                this.sfln(constPfx + cTypeDecl(ftype, name + "__" + fname) + " = " + initExpr + ";");
            }
        }
    }

    // ── Enum ─────────────────────────────────────────────────────────────

    void emitEnum(AstNode* en) {
        string name = mangleName(en.get("name"));
        this.eln("typedef int64_t " + name + ";");
        for (int i = 0; i < en.numChildren(); ++i) {
            AstNode* v = en.child(i);
            if (v.tag == "VARIANT") {
                string vname = v.get("name");
                int val = v.getInt("val");
                this.eln("#define " + name + "__" + vname + " ((int64_t)" + strings::intToStr(val) + ")");
            }
        }
        this.eln("");
    }

    // ── Union structs ─────────────────────────────────────────────────────

    void emitUnionStruct(AstNode* un) {
        string rawName = un.get("name");
        string name = mangleName(rawName);

        // tag enum
        this.sln("typedef enum {");
        for (int i = 0; i < un.numChildren(); ++i) {
            AstNode* v = un.child(i);
            if (v.tag == "UNION_VARIANT") {
                this.sln("    " + name + "__" + v.get("name") + ",");
            }
        }
        this.sln("} " + name + "_tag;");
        this.sln("");

        // struct with tag + union
        this.sln("struct " + name + " {");
        this.sln("    " + name + "_tag tag;");
        this.sln("    union {");
        for (int i = 0; i < un.numChildren(); ++i) {
            AstNode* v = un.child(i);
            if (v.tag == "UNION_VARIANT") {
                string vname = v.get("name");
                if (v.numChildren() == 0) {
                    this.sln("        struct { int __dummy; } as_" + vname + ";");
                } else {
                    this.sln("        struct {");
                    for (int j = 0; j < v.numChildren(); ++j) {
                        AstNode* f = v.child(j);
                        if (f.tag == "UNION_FIELD") {
                            string ftype = f.get("type");
                            string fname = f.get("name");
                            // Class-typed variant fields are references (pointers),
                            // matching how ordinary class fields are emitted.
                            if (this.info.isClass(ftype)) { ftype = ftype + "*"; }
                            this.sln("            " + cTypeDecl(ftype, fname) + ";");
                        }
                    }
                    this.sln("        } as_" + vname + ";");
                }
            }
        }
        this.sln("    } data;");
        this.sln("};");
        this.sln("");

        // constructor functions for each variant
        for (int i = 0; i < un.numChildren(); ++i) {
            AstNode* v = un.child(i);
            if (v.tag == "UNION_VARIANT") {
                string vname = v.get("name");
                // build param list
                StringBuilder plist = StringBuilder();
                bool first = true;
                for (int j = 0; j < v.numChildren(); ++j) {
                    AstNode* f = v.child(j);
                    if (f.tag == "UNION_FIELD") {
                        if (!first) { plist.append(", "); }
                        string fty = f.get("type");
                        if (this.info.isClass(fty)) { fty = fty + "*"; }
                        plist.append(cTypeDecl(fty, f.get("name")));
                        first = false;
                    }
                }
                // empty struct needs no params
                string params = plist.build();
                if (v.numChildren() == 0) {
                    this.sln("static " + name + " " + name + "__" + vname + "_new(void) {");
                } else {
                    this.sln("static " + name + " " + name + "__" + vname + "_new(" + params + ") {");
                }
                this.sln("    " + name + " __v;");
                this.sln("    __v.tag = " + name + "__" + vname + ";");
                for (int j = 0; j < v.numChildren(); ++j) {
                    AstNode* f = v.child(j);
                    if (f.tag == "UNION_FIELD") {
                        string fname = f.get("name");
                        this.sln("    __v.data.as_" + vname + "." + fname + " = " + fname + ";");
                    }
                }
                this.sln("    return __v;");
                this.sln("}");
                this.sln("");
            }
        }
    }

    // ── Prototypes ───────────────────────────────────────────────────────

    void emitPrototype(AstNode* decl) {
        string tag = decl.tag;
        if (tag == "FUNC") {
            string name = mangleName(decl.get("name"));
            string cname = name;
            if (name == "main") { cname = "glang_main"; }
            string ret = this.cRetType(decl.get("ret"));
            string plist = this.buildParamList(decl, "");
            this.prln(ret + " " + cname + "(" + plist + ");");
        } else if (tag == "CLASS") {
            string rawName = decl.get("name");
            string name = mangleName(rawName);
            // constructor
            if (decl.getBool("has_ctor")) {
                AstNode* ctor = this.findChild(decl, "CTOR");
                if (ctor != null) {
                    string plist = this.buildParamList(ctor, "");
                    string initPlist = this.buildParamList(ctor, name + "* self");
                    this.prln("void " + name + "__init(" + initPlist + ");");
                    this.prln(name + "* " + name + "_new(" + plist + ");");
                }
            } else {
                this.prln("void " + name + "__init(" + name + "* self);");
                this.prln(name + "* " + name + "_new(void);");
            }
            // destructor
            if (decl.getBool("has_dtor")) {
                this.prln("void " + name + "_dtor(" + name + "* self);");
            }
            this.prln("void " + name + "_delete(" + name + "* self);");
            // methods
            for (int i = 0; i < decl.numChildren(); ++i) {
                AstNode* ch = decl.child(i);
                if (ch.tag == "METHOD") {
                    string mname = ch.get("name");
                    string ret = this.cRetType(ch.get("ret"));
                    string plist = "";
                    if (ch.getBool("static")) {
                        plist = this.buildParamList(ch, "");
                    } else {
                        plist = this.buildParamList(ch, name + "* self");
                    }
                    string cname2 = name + "__" + mangleName(mname);
                    this.prln(ret + " " + cname2 + "(" + plist + ");");
                }
            }
        } else if (tag == "MODIFIER") {
            string target = mangleName(decl.get("target"));
            for (int i = 0; i < decl.numChildren(); ++i) {
                AstNode* ch = decl.child(i);
                if (ch.tag == "METHOD") {
                    string mname = ch.get("name");
                    string ret = this.cRetType(ch.get("ret"));
                    string targ = mangleName(decl.get("target"));
                    // self type: if class use pointer, else value
                    string selfParam = cTypeOf(decl.get("target")) + " self";
                    if (this.info.isClass(decl.get("target"))) {
                        selfParam = targ + "* self";
                    }
                    string plist = this.buildParamListWith(ch, selfParam);
                    string cname2 = targ + "__" + mangleName(mname);
                    this.prln(ret + " " + cname2 + "(" + plist + ");");
                }
            }
        }
    }

    // ── Full declarations ────────────────────────────────────────────────

    void emitDecl(AstNode* decl) {
        string tag = decl.tag;
        if (tag == "FUNC") {
            this.emitFunc(decl);
        } else if (tag == "CLASS") {
            this.emitClass(decl);
        } else if (tag == "MODIFIER") {
            this.emitModifier(decl);
        }
        // ENUM, UNION, INTERFACE: already emitted in struct/enum passes
    }

    // ── Function emission ────────────────────────────────────────────────

    void emitFunc(AstNode* funcNode) {
        string rawName = funcNode.get("name");
        string name = mangleName(rawName);
        string cname = name;
        if (name == "main") { cname = "glang_main"; }
        string ret = this.cRetType(funcNode.get("ret"));
        this.currentRetType = funcNode.get("ret");
        string plist = this.buildParamList(funcNode, "");

        this.out.appendLine("");
        this.out.appendLine(ret + " " + cname + "(" + plist + ") {");
        this.indentLevel = 1;

        // Set up scope and emit params as locals
        this.typer.pushScope();
        this.typer.currentClass = "";
        for (int i = 0; i < funcNode.numChildren(); ++i) {
            AstNode* ch = funcNode.child(i);
            if (ch.tag == "PARAM") {
                string __pt = ch.get("type"); if (this.info.isClass(__pt)) { __pt = __pt + "*"; } this.typer.define(ch.get("name"), __pt);
            } else if (ch.tag == "BLOCK") {
                this.emitBlock(ch);
            }
        }
        this.typer.popScope();

        this.indentLevel = 0;
        this.out.appendLine("}");
    }

    // ── Class emission ───────────────────────────────────────────────────

    void emitClass(AstNode* cls) {
        string rawName = cls.get("name");
        string name = mangleName(rawName);

        // Constructor
        AstNode* ctor = this.findChild(cls, "CTOR");
        if (ctor != null) {
            this.emitConstructor(ctor, name, cls);
        } else {
            // Default constructor: __init does nothing, _new allocates
            this.out.appendLine("");
            this.out.appendLine("void " + name + "__init(" + name + "* self) {");
            // Call super __init if we have a super
            string superNameDef = cls.get("super");
            if (superNameDef != "") {
                string snameDef = mangleName(superNameDef);
                this.out.appendLine("    " + snameDef + "__init((" + snameDef + "*)self);");
            }
            this.out.appendLine("}");
            this.out.appendLine("");
            this.out.appendLine(name + "* " + name + "_new(void) {");
            this.out.appendLine("    " + name + "* self = (" + name + "*)calloc(1, sizeof(" + name + "));");
            this.out.appendLine("    " + name + "__init(self);");
            this.out.appendLine("    return self;");
            this.out.appendLine("}");
        }

        // Destructor
        AstNode* dtor = this.findChild(cls, "DTOR");
        if (dtor != null) {
            this.emitDestructor(dtor, name);
        }
        // delete function (always emitted)
        this.out.appendLine("");
        this.out.appendLine("void " + name + "_delete(" + name + "* self) {");
        this.out.appendLine("    if (self == NULL) return;");
        if (dtor != null) {
            this.out.appendLine("    " + name + "_dtor(self);");
        }
        // call superclass destructor if it has one
        string superName = cls.get("super");
        if (superName != "") {
            string sname = mangleName(superName);
            this.out.appendLine("    " + sname + "_delete((" + sname + "*)self);");
            this.out.appendLine("    return; /* parent free() handles memory */");
        } else {
            this.out.appendLine("    free(self);");
        }
        this.out.appendLine("}");

        // Methods
        for (int i = 0; i < cls.numChildren(); ++i) {
            AstNode* ch = cls.child(i);
            if (ch.tag == "METHOD") {
                this.emitMethod(ch, name, rawName);
            }
        }
    }

    void emitConstructor(AstNode* ctor, string name, AstNode* cls) {
        string plist = this.buildParamList(ctor, "");
        string initPlist = this.buildParamList(ctor, name + "* self");

        // Emit __init function (does initialization without allocation)
        this.out.appendLine("");
        this.out.appendLine("void " + name + "__init(" + initPlist + ") {");
        this.indentLevel = 1;

        this.typer.pushScope();
        this.typer.currentClass = cls.get("name");
        this.typer.define("self", name + "*");

        // define params
        for (int i = 0; i < ctor.numChildren(); ++i) {
            AstNode* ch = ctor.child(i);
            if (ch.tag == "PARAM") {
                string __pt = ch.get("type"); if (this.info.isClass(__pt)) { __pt = __pt + "*"; } this.typer.define(ch.get("name"), __pt);
            }
        }

        // super call (if any)
        string superName = cls.get("super");
        if (ctor.getBool("has_super") && superName != "") {
            string sname = mangleName(superName);
            // collect SUPER_ARG children
            List<string> superArgExprs = List<string>();
            for (int i = 0; i < ctor.numChildren(); ++i) {
                AstNode* ch = ctor.child(i);
                if (ch.tag == "SUPER_ARG" && ch.numChildren() > 0) {
                    superArgExprs.add(this.emitExpr(ch.child(0)));
                }
            }
            // Build super args string with self cast
            StringBuilder superCall = StringBuilder();
            superCall.append(sname + "__init((" + sname + "*)self");
            for (int i = 0; i < superArgExprs.length(); ++i) {
                superCall.append(", " + superArgExprs.get(i));
            }
            superCall.append(")");
            this.ln(superCall.build() + ";");
        }

        // Constructor body
        for (int i = 0; i < ctor.numChildren(); ++i) {
            AstNode* ch = ctor.child(i);
            if (ch.tag == "BLOCK") {
                this.emitBlock(ch);
            }
        }

        this.typer.popScope();
        this.indentLevel = 0;
        this.out.appendLine("}");

        // Emit _new function (allocates + calls __init)
        this.out.appendLine("");
        this.out.appendLine(name + "* " + name + "_new(" + plist + ") {");
        this.out.appendLine("    " + name + "* self = (" + name + "*)calloc(1, sizeof(" + name + "));");

        // Build __init call with params
        StringBuilder initCall = StringBuilder();
        initCall.append("    " + name + "__init(self");
        for (int i = 0; i < ctor.numChildren(); ++i) {
            AstNode* ch = ctor.child(i);
            if (ch.tag == "PARAM") {
                initCall.append(", " + ch.get("name"));
            }
        }
        initCall.append(");");
        this.out.appendLine(initCall.build());
        this.out.appendLine("    return self;");
        this.out.appendLine("}");
    }

    void emitDestructor(AstNode* dtor, string name) {
        this.out.appendLine("");
        this.out.appendLine("void " + name + "_dtor(" + name + "* self) {");
        this.indentLevel = 1;
        this.typer.pushScope();
        this.typer.define("self", name + "*");
        for (int i = 0; i < dtor.numChildren(); ++i) {
            AstNode* ch = dtor.child(i);
            if (ch.tag == "BLOCK") {
                this.emitBlock(ch);
            }
        }
        this.typer.popScope();
        this.indentLevel = 0;
        this.out.appendLine("}");
    }

    void emitMethod(AstNode* method, string clsName, string rawClsName) {
        string mname = method.get("name");
        string ret = this.cRetType(method.get("ret"));
        this.currentRetType = method.get("ret");
        bool isStatic = method.getBool("static");
        string cname = clsName + "__" + mangleName(mname);
        string plist = "";
        if (isStatic) {
            plist = this.buildParamList(method, "");
        } else {
            plist = this.buildParamList(method, clsName + "* self");
        }

        this.out.appendLine("");
        this.out.appendLine(ret + " " + cname + "(" + plist + ") {");
        this.indentLevel = 1;

        this.typer.pushScope();
        this.typer.currentClass = rawClsName;
        if (!isStatic) {
            this.typer.define("self", clsName + "*");
        }
        for (int i = 0; i < method.numChildren(); ++i) {
            AstNode* ch = method.child(i);
            if (ch.tag == "PARAM") {
                string __pt = ch.get("type"); if (this.info.isClass(__pt)) { __pt = __pt + "*"; } this.typer.define(ch.get("name"), __pt);
            } else if (ch.tag == "BLOCK") {
                this.emitBlock(ch);
            }
        }
        this.typer.popScope();
        this.indentLevel = 0;
        this.out.appendLine("}");
    }

    // ── Modifier emission ────────────────────────────────────────────────

    void emitModifier(AstNode* mod) {
        string rawTarget = mod.get("target");
        string target = mangleName(rawTarget);
        string selfParam = cTypeOf(rawTarget) + " self";
        if (this.info.isClass(rawTarget)) {
            selfParam = target + "* self";
        }

        for (int i = 0; i < mod.numChildren(); ++i) {
            AstNode* ch = mod.child(i);
            if (ch.tag == "METHOD") {
                string mname = ch.get("name");
                string ret = this.cRetType(ch.get("ret"));
                string cname = target + "__" + mangleName(mname);
                string plist = this.buildParamListWith(ch, selfParam);

                this.out.appendLine("");
                this.out.appendLine(ret + " " + cname + "(" + plist + ") {");
                this.indentLevel = 1;

                this.typer.pushScope();
                this.typer.currentClass = rawTarget;
                this.typer.define("self", rawTarget);
                for (int j = 0; j < ch.numChildren(); ++j) {
                    AstNode* p = ch.child(j);
                    if (p.tag == "PARAM") {
                        this.typer.define(p.get("name"), p.get("type"));
                    } else if (p.tag == "BLOCK") {
                        this.emitBlock(p);
                    }
                }
                this.typer.popScope();
                this.indentLevel = 0;
                this.out.appendLine("}");
            }
        }
    }

    // ── Statements ───────────────────────────────────────────────────────

    void emitBlock(AstNode* block) {
        this.typer.pushScope();
        int n = block.numChildren();
        for (int i = 0; i < n; ++i) {
            this.emitStmt(block.child(i));
        }
        this.typer.popScope();
    }

    void emitStmt(AstNode* s) {
        if (s == null) { return; }
        string tag = s.tag;

        if (tag == "BLOCK") {
            this.ln("{");
            this.indentLevel = this.indentLevel + 1;
            this.emitBlock(s);
            this.indentLevel = this.indentLevel - 1;
            this.ln("}");
        } else if (tag == "VARDECL") {
            this.emitVarDecl(s);
        } else if (tag == "ASSIGN") {
            string target = this.emitExpr(s.child(0));
            string value  = this.emitExpr(s.child(1));
            // If assigning a free function to a fn-pointer variable, wrap as GlangFn
            AstNode* rhs = s.child(1);
            if (rhs.tag == "IDENT") {
                string iname = rhs.get("name");
                string tname = "";
                AstNode* lhs = s.child(0);
                if (lhs.tag == "IDENT") { tname = lhs.get("name"); }
                string targetType = this.typer.lookup(tname);
                if (startsWith(targetType, "fn(") && this.typer.lookup(iname) == "" && this.info.funcRet.getOr(iname, "") != "") {
                    value = this.wrapAsGlangFn(mangleName(iname), targetType);
                }
            }
            this.ln(target + " " + s.get("op") + " " + value + ";");
        } else if (tag == "IF") {
            this.emitIf(s);
        } else if (tag == "WHILE") {
            string cond = this.emitExpr(s.child(0));
            this.ln("while (" + cond + ") {");
            this.indentLevel = this.indentLevel + 1;
            this.emitBlock(s.child(1));
            this.indentLevel = this.indentLevel - 1;
            this.ln("}");
        } else if (tag == "DOWHILE") {
            this.ln("do {");
            this.indentLevel = this.indentLevel + 1;
            this.emitBlock(s.child(0));
            this.indentLevel = this.indentLevel - 1;
            string cond = this.emitExpr(s.child(1));
            this.ln("} while (" + cond + ");");
        } else if (tag == "FOR") {
            this.emitFor(s);
        } else if (tag == "FOREACH") {
            this.emitForeach(s);
        } else if (tag == "USING_STMT") {
            this.emitUsing(s);
        } else if (tag == "BREAK") {
            this.ln("break;");
        } else if (tag == "CONTINUE") {
            this.ln("continue;");
        } else if (tag == "RETURN") {
            if (s.getBool("has_val") && s.numChildren() > 0) {
                string val = this.emitExpr(s.child(0));
                this.ln("return " + val + ";");
            } else {
                this.ln("return;");
            }
        } else if (tag == "THROW") {
            string val = this.emitExpr(s.child(0));
            // The runtime class name drives catch's instanceof.  Use the NEW
            // class directly; otherwise infer the thrown expression's static
            // type (e.g. `throw stream.error(...)` returns a ParseError*), so a
            // thrown subclass is caught by `catch (Subclass* e)` rather than
            // defaulting to the base Exception and slipping past the handler.
            string cls = "Exception";
            AstNode* child = s.child(0);
            if (child.tag == "NEW") {
                cls = mangleName(child.get("cls"));
            } else {
                string thrownType = this.typer.infer(child);
                if (endsWith(thrownType, "*")) {
                    thrownType = substr(thrownType, 0, len(thrownType) - 1);
                }
                if (this.info.isClass(thrownType)) { cls = mangleName(thrownType); }
            }
            this.ln("GLANG_THROW(" + val + ", \"" + cls + "\");");
        } else if (tag == "TRY") {
            this.emitTryCatch(s);
        } else if (tag == "MATCH") {
            this.emitMatch(s);
        } else {
            // Expression used as statement
            string expr = this.emitExpr(s);
            if (expr != "" && expr != "/* noop */") {
                this.ln(expr + ";");
            }
        }
    }

    void emitVarDecl(AstNode* vd) {
        string name = vd.get("name");
        string type = vd.get("type");
        // Class types are reference semantics in Glang — use pointer in C
        string ctype = type;
        if (this.info.isClass(type)) { ctype = type + "*"; }
        string initExpr = "";
        if (vd.numChildren() > 0) {
            AstNode* initNode = vd.child(0);
            initExpr = this.emitExpr(initNode);
            // If assigning a free function reference to a fn-pointer variable, wrap as GlangFn
            if (startsWith(type, "fn(") && initNode.tag == "IDENT") {
                string iname = initNode.get("name");
                // Check if it's a free function (not a local fn-pointer variable)
                if (this.typer.lookup(iname) == "" && this.info.funcRet.getOr(iname, "") != "") {
                    initExpr = this.wrapAsGlangFn(mangleName(iname), type);
                }
            }
        }
        // Register type for inferencer (use pointer type so field access uses ->)
        this.typer.define(name, ctype);
        // Emit
        string decl = cTypeDecl(ctype, name);
        if (initExpr != "") {
            this.ln(decl + " = " + initExpr + ";");
        } else {
            this.ln(decl + ";");
        }
    }

    void emitIf(AstNode* s) {
        string cond = this.emitExpr(s.child(0));
        this.ln("if (" + cond + ") {");
        this.indentLevel = this.indentLevel + 1;
        this.emitBlock(s.child(1));
        this.indentLevel = this.indentLevel - 1;

        bool hasElse = s.getBool("has_else");
        bool elseIsIf = s.getBool("else_is_if");
        if (hasElse && s.numChildren() > 2) {
            if (elseIsIf) {
                this.ln("} else ");
                this.raw("");
                // The else-if node
                AstNode* elseIf = s.child(2);
                // Temporarily un-indent the "if" part
                this.emitInlineIf(elseIf);
            } else {
                this.ln("} else {");
                this.indentLevel = this.indentLevel + 1;
                this.emitBlock(s.child(2));
                this.indentLevel = this.indentLevel - 1;
                this.ln("}");
            }
        } else if (!hasElse) {
            this.ln("}");
        }
    }

    void emitInlineIf(AstNode* s) {
        // Like emitIf but the opening brace is on the same line as "} else"
        string cond = this.emitExpr(s.child(0));
        this.ln("if (" + cond + ") {");
        this.indentLevel = this.indentLevel + 1;
        this.emitBlock(s.child(1));
        this.indentLevel = this.indentLevel - 1;

        bool hasElse = s.getBool("has_else");
        bool elseIsIf = s.getBool("else_is_if");
        if (hasElse && s.numChildren() > 2) {
            if (elseIsIf) {
                this.ln("} else ");
                this.emitInlineIf(s.child(2));
            } else {
                this.ln("} else {");
                this.indentLevel = this.indentLevel + 1;
                this.emitBlock(s.child(2));
                this.indentLevel = this.indentLevel - 1;
                this.ln("}");
            }
        } else {
            this.ln("}");
        }
    }

    void emitFor(AstNode* s) {
        // Children: VARDECL, condition-expr, post-stmt, BLOCK
        AstNode* init  = s.child(0);
        AstNode* cond  = s.child(1);
        AstNode* post  = s.child(2);
        AstNode* body  = s.child(3);

        string varName = init.get("name");
        string varType = init.get("type");
        string initVal = "";
        if (init.numChildren() > 0) {
            initVal = this.emitExpr(init.child(0));
        }
        string condStr = this.emitExpr(cond);
        string postStr = this.emitPostExpr(post);

        this.typer.define(varName, varType);
        this.ln("for (" + cTypeDecl(varType, varName) + " = " + initVal + "; " +
                condStr + "; " + postStr + ") {");
        this.indentLevel = this.indentLevel + 1;
        this.emitBlock(body);
        this.indentLevel = this.indentLevel - 1;
        this.ln("}");
    }

    // Emit an AssignStmt or UnaryExpr as a for-loop post expression (no semicolon)
    string emitPostExpr(AstNode* post) {
        if (post == null) { return ""; }
        string tag = post.tag;
        if (tag == "ASSIGN") {
            string target = this.emitExpr(post.child(0));
            string value  = this.emitExpr(post.child(1));
            return target + " " + post.get("op") + " " + value;
        }
        if (tag == "UNARY") {
            string op = post.get("op");
            string operand = this.emitExpr(post.child(0));
            if (op == "++" || op == "--") {
                return op + operand;
            }
            return op + operand;
        }
        return this.emitExpr(post);
    }

    void emitForeach(AstNode* s) {
        string varName  = s.get("var");
        string varType  = s.get("type");
        AstNode* iter   = s.child(0);
        AstNode* body   = s.child(1);

        string iterStr  = this.emitExpr(iter);
        string iterType = this.typer.infer(iter);

        this.typer.define(varName, varType);

        // Dispatch on iterable type
        if (iterType == "string") {
            // foreach (char c in str) → for loop over chars
            string lenStr = "(int64_t)strlen(" + iterStr + ")";
            this.ln("{");
            this.indentLevel = this.indentLevel + 1;
            this.ln("char* __iter__ = " + iterStr + ";");
            this.ln("int64_t __len__ = (int64_t)strlen(__iter__);");
            this.ln("for (int64_t __i__ = 0; __i__ < __len__; __i__++) {");
            this.indentLevel = this.indentLevel + 1;
            this.ln(cTypeOf(varType) + " " + varName + " = __iter__[__i__];");
            this.emitBlock(body);
            this.indentLevel = this.indentLevel - 1;
            this.ln("}");
            this.indentLevel = this.indentLevel - 1;
            this.ln("}");
        } else if (endsWith(iterType, "]")) {
            // fixed-size array
            int lb = strings::indexOf(iterType, '[');
            string size = "";
            if (lb >= 0) { size = substr(iterType, lb + 1, len(iterType) - 1); }
            this.ln("{");
            this.indentLevel = this.indentLevel + 1;
            this.ln("int64_t __len__ = (int64_t)" + size + ";");
            this.ln("for (int64_t __i__ = 0; __i__ < __len__; __i__++) {");
            this.indentLevel = this.indentLevel + 1;
            this.ln(cTypeDecl(varType, varName) + " = (" + iterStr + ")[__i__];");
            this.emitBlock(body);
            this.indentLevel = this.indentLevel - 1;
            this.ln("}");
            this.indentLevel = this.indentLevel - 1;
            this.ln("}");
        } else {
            // Generic: use .length() and .get() — works for List<T>
            // Strip pointer if needed to get the mangled type name
            string baseIterType = iterType;
            if (endsWith(iterType, "*")) {
                baseIterType = substr(iterType, 0, len(iterType) - 1);
            }
            string mangledIter = mangleName(baseIterType);
            string iterCType = cTypeOf(iterType);
            this.ln("{");
            this.indentLevel = this.indentLevel + 1;
            this.ln(iterCType + " __iter__ = " + iterStr + ";");
            // If already a pointer, call directly; otherwise take address
            string selfRef = "&__iter__";
            if (endsWith(iterType, "*")) { selfRef = "__iter__"; }
            this.ln("int64_t __len__ = " + mangledIter + "__length(" + selfRef + ");");
            this.ln("for (int64_t __i__ = 0; __i__ < __len__; __i__++) {");
            this.indentLevel = this.indentLevel + 1;
            this.ln(cTypeDecl(varType, varName) + " = " + mangledIter + "__get(" + selfRef + ", __i__);");
            this.emitBlock(body);
            this.indentLevel = this.indentLevel - 1;
            this.ln("}");
            this.indentLevel = this.indentLevel - 1;
            this.ln("}");
        }
    }

    void emitUsing(AstNode* s) {
        AstNode* decl = s.child(0);
        AstNode* body = s.child(1);
        int uid = this.usingCounter;
        this.usingCounter = this.usingCounter + 1;

        string varName = decl.get("name");
        string varType = decl.get("type");
        string initExpr = "";
        if (decl.numChildren() > 0) {
            initExpr = this.emitExpr(decl.child(0));
        }

        this.typer.define(varName, varType);
        this.ln("{");
        this.indentLevel = this.indentLevel + 1;
        this.ln(cTypeDecl(varType, varName) + " = " + initExpr + ";");
        this.emitBlock(body);
        // Dispose
        string mangledType = mangleName(varType);
        if (endsWith(varType, "*")) {
            this.ln(mangledType + "_delete(" + varName + ");");
        } else if (this.info.isClass(varType)) {
            this.ln(mangledType + "__dispose(&" + varName + ");");
        }
        this.indentLevel = this.indentLevel - 1;
        this.ln("}");
    }

    void emitTryCatch(AstNode* s) {
        AstNode* tryBlock = s.child(0);
        int numCatches = s.getInt("catches");

        this.ln("GLANG_TRY_BEGIN");
        this.indentLevel = this.indentLevel + 1;
        this.emitBlock(tryBlock);
        this.indentLevel = this.indentLevel - 1;
        this.ln("GLANG_TRY_END");

        // Catch clauses start at child 1
        for (int i = 0; i < numCatches; ++i) {
            AstNode* catch_ = s.child(1 + i);
            if (catch_.tag == "CATCH") {
                string rawCtype = catch_.get("type");
                // Exception catch vars are always pointers in C
                string baseType = mangleName(rawCtype);
                if (endsWith(baseType, "*")) {
                    baseType = substr(baseType, 0, len(baseType) - 1);
                }
                string ptrType = baseType + "*";
                string cvar = catch_.get("var");
                if (i > 0) { this.ln("else"); }
                this.ln("if (glang_instanceof(__exc_frame__.class_name, \"" + baseType +
                        "\", __glang_hier__, __glang_hier_len__)) {");
                this.indentLevel = this.indentLevel + 1;
                this.ln(ptrType + " " + cvar + " = (" + ptrType + ")__exc_frame__.obj;");
                this.typer.define(cvar, ptrType);
                AstNode* catchBody = catch_.child(0);
                if (catchBody != null) { this.emitBlock(catchBody); }
                this.indentLevel = this.indentLevel - 1;
                this.ln("}");
            }
        }
        // If nothing caught, re-throw
        this.ln("else { GLANG_THROW(__exc_frame__.obj, __exc_frame__.class_name); }");
        this.ln("GLANG_CATCH_DONE");
    }

    void emitMatch(AstNode* s) {
        AstNode* scrutinee = s.child(0);
        string scrutType   = mangleName(this.typer.infer(scrutinee));
        string scrutExpr   = this.emitExpr(scrutinee);
        int numArms        = s.getInt("arms");

        this.ln("{");
        this.indentLevel = this.indentLevel + 1;
        this.ln(scrutType + " __match__ = " + scrutExpr + ";");
        this.ln("switch (__match__.tag) {");

        for (int i = 0; i < numArms; ++i) {
            AstNode* arm = s.child(1 + i);
            if (arm.getBool("is_wild")) {
                this.ln("default: {");
                this.indentLevel = this.indentLevel + 1;
                AstNode* body = arm.child(0);
                if (body != null) { this.emitBlock(body); }
                this.ln("break;");
                this.indentLevel = this.indentLevel - 1;
                this.ln("}");
            } else {
                string union_ = mangleName(arm.get("union"));
                string variant = arm.get("variant");
                this.ln("case " + union_ + "__" + variant + ": {");
                this.indentLevel = this.indentLevel + 1;

                int numBindings = arm.getInt("bindings");
                // Collect BIND children
                List<string> bindings = List<string>();
                AstNode* armBody = null;
                for (int j = 0; j < arm.numChildren(); ++j) {
                    AstNode* ch = arm.child(j);
                    if (ch.tag == "BIND") { bindings.add(ch.get("name")); }
                    else if (ch.tag == "BLOCK") { armBody = ch; }
                }

                // Extract bindings from union variant fields
                for (int j = 0; j < bindings.length(); ++j) {
                    string bname = bindings.get(j);
                    string fkey = union_ + "." + variant + "." + strings::intToStr(j);
                    string finfo = this.info.unionFieldAt.getOr(fkey, "");
                    string fname = bname;
                    string ftype = "int";
                    if (len(finfo) > 0) {
                        int colon = indexOf(finfo, ":");
                        if (colon >= 0) {
                            fname = substr(finfo, 0, colon);
                            ftype = substr(finfo, colon + 1, len(finfo));
                        }
                    }
                    // Class-typed variant fields are stored as references, so the
                    // binding is a pointer too (mirrors how class fields/params bind).
                    string boundType = ftype;
                    if (this.info.isClass(ftype)) { boundType = ftype + "*"; }
                    this.ln(cTypeDecl(boundType, bname) + " = __match__.data.as_" + variant + "." + fname + ";");
                    this.typer.define(bname, boundType);
                }

                if (armBody != null) { this.emitBlock(armBody); }
                this.ln("break;");
                this.indentLevel = this.indentLevel - 1;
                this.ln("}");
            }
        }
        this.ln("}");
        this.indentLevel = this.indentLevel - 1;
        this.ln("}");
    }

    // ── Expressions ──────────────────────────────────────────────────────

    string emitExpr(AstNode* e) {
        if (e == null) { return "0"; }
        string tag = e.tag;

        if (tag == "LIT")  { return this.emitLit(e); }
        if (tag == "NULL") { return "NULL"; }
        if (tag == "THIS") { return "self"; }
        if (tag == "SUPER") { return "self"; }  // cast happens at call site
        if (tag == "IDENT") {
            string name = e.get("name");
            // Static field access: ClassName.field → ClassName__field
            return mangleName(name);
        }
        if (tag == "BINARY") { return this.emitBinary(e); }
        if (tag == "UNARY")  { return this.emitUnary(e); }
        if (tag == "CAST")   { return this.emitCast(e); }
        if (tag == "CALL")   { return this.emitCall(e); }
        if (tag == "INDIRECT_CALL") { return this.emitIndirectCall(e); }
        if (tag == "METHOD_CALL")   { return this.emitMethodCall(e); }
        if (tag == "NEW")           { return this.emitNew(e); }
        if (tag == "DELETE")        { return this.emitDelete(e); }
        if (tag == "ALLOC")         { return this.emitAlloc(e); }
        if (tag == "FREE") {
            string op = this.emitExpr(e.child(0));
            return "free(" + op + ")";
        }
        if (tag == "FIELD_ACCESS") {
            string obj      = this.emitExpr(e.child(0));
            string field    = e.get("field");
            string baseType = this.typer.infer(e.child(0));
            // Strip pointer for lookup
            string lookupType = baseType;
            if (endsWith(baseType, "*")) {
                lookupType = substr(baseType, 0, len(baseType) - 1);
            }
            // Enum member access: EnumType.VARIANT → EnumType__VARIANT
            if (this.info.isEnum(lookupType)) {
                return mangleName(lookupType) + "__" + field;
            }
            // Static field on a type name used as namespace
            AstNode* baseNode = e.child(0);
            if (baseNode.tag == "IDENT") {
                string bname = baseNode.get("name");
                if (this.info.isEnum(bname)) {
                    return mangleName(bname) + "__" + field;
                }
                // Zero-field union variant construction: JsonValue.Null → JsonValue__Null_new()
                if (this.info.isUnion(bname)) {
                    return mangleName(bname) + "__" + field + "_new()";
                }
            }
            // Use -> when base is a pointer or a class (which is heap-ref in Glang)
            bool isRef = endsWith(baseType, "*") || this.info.isClass(lookupType);
            if (isRef) { return obj + "->" + field; }
            return obj + "." + field;
        }
        if (tag == "ARROW_ACCESS") {
            string ptr   = this.emitExpr(e.child(0));
            string field = e.get("field");
            return ptr + "->" + field;
        }
        if (tag == "INDEX") {
            string arr = this.emitExpr(e.child(0));
            string idx = this.emitExpr(e.child(1));
            return arr + "[" + idx + "]";
        }
        if (tag == "ADDRESS_OF") {
            return "&" + this.emitExpr(e.child(0));
        }
        if (tag == "DEREF") {
            return "*" + this.emitExpr(e.child(0));
        }
        if (tag == "CLOSURE") {
            return this.emitClosure(e);
        }
        return "/* unknown:" + tag + " */0";
    }

    string emitLit(AstNode* e) {
        string kind = e.get("kind");
        string val  = e.get("val");
        if (kind == "int")    { return val; }
        if (kind == "float")  { return val; }
        if (kind == "bool")   {
            if (val == "true")  { return "1"; }
            return "0";
        }
        if (kind == "char") {
            // Escape special chars
            if (val == "\n")   { return "'\\n'"; }
            if (val == "\t")   { return "'\\t'"; }
            if (val == "\r")   { return "'\\r'"; }
            if (val == "\\")   { return "'\\\\'"; }
            if (val == "'")    { return "'\\''"; }
            if (val == "\0")   { return "'\\0'"; }
            if (len(val) == 1) { return "'" + val + "'"; }
            return "'" + val + "'";
        }
        if (kind == "string") {
            // Build a C string literal with proper escaping
            StringBuilder sb = StringBuilder();
            sb.appendChar('"');
            int n = len(val);
            for (int i = 0; i < n; ++i) {
                char c = val[i];
                if (c == '"')  { sb.append("\\\""); }
                else if (c == '\\') { sb.append("\\\\"); }
                else if (c == '\n') { sb.append("\\n"); }
                else if (c == '\r') { sb.append("\\r"); }
                else if (c == '\t') { sb.append("\\t"); }
                else { sb.appendChar(c); }
            }
            sb.appendChar('"');
            return sb.build();
        }
        return val;
    }

    string emitBinary(AstNode* e) {
        string op    = e.get("op");
        string left  = this.emitExpr(e.child(0));
        string right = this.emitExpr(e.child(1));

        if (op == "??") {
            // null-coalescing: (left != NULL ? left : right)
            return "(" + left + " != NULL ? " + left + " : " + right + ")";
        }
        // String operations
        string lt = this.typer.infer(e.child(0));
        string rt = this.typer.infer(e.child(1));
        if (op == "+" && (lt == "string" || rt == "string")) {
            return "glang_str_concat(" + left + ", " + right + ")";
        }
        // String equality/inequality must use strcmp
        if ((op == "==" || op == "!=") && (lt == "string" || rt == "string")) {
            if (op == "==") { return "(strcmp(" + left + ", " + right + ") == 0)"; }
            return "(strcmp(" + left + ", " + right + ") != 0)";
        }
        return "(" + left + " " + op + " " + right + ")";
    }

    string emitUnary(AstNode* e) {
        string op = e.get("op");
        string operand = this.emitExpr(e.child(0));
        if (op == "unary-") { return "(-" + operand + ")"; }
        if (op == "unary+") { return "(+" + operand + ")"; }
        if (op == "++" || op == "--") { return op + operand; }
        return op + operand;
    }

    string emitCast(AstNode* e) {
        string to   = e.get("to");
        string expr = this.emitExpr(e.child(0));
        return "((" + cTypeOf(to) + ")" + expr + ")";
    }

    string emitCall(AstNode* e) {
        string name = e.get("name");
        int numArgs = e.getInt("args");

        // Collect arg expressions
        List<string> argStrs = List<string>();
        for (int i = 0; i < numArgs; ++i) {
            argStrs.add(this.emitExpr(e.child(i)));
        }

        // Check if name refers to a fn-pointer variable (GlangFn in C)
        string fnPtrType = this.typer.lookup(name);
        if (startsWith(fnPtrType, "fn(")) {
            return emitGlangFnCall(mangleName(name), fnPtrType, argStrs);
        }

        // Built-in dispatch
        if (name == "print") {
            return this.emitPrint(e, argStrs, false);
        }
        if (name == "printErr") {
            return this.emitPrint(e, argStrs, true);
        }
        if (name == "toString") {
            if (argStrs.length() > 0) {
                string t = this.typer.infer(e.child(0));
                return "glang_tostring_" + t + "(" + argStrs.get(0) + ")";
            }
            return "\"\"";
        }
        if (name == "len") {
            if (argStrs.length() > 0) {
                AstNode* arg = e.child(0);
                string t = this.typer.infer(arg);
                if (t == "string") { return "(int64_t)strlen(" + argStrs.get(0) + ")"; }
                // array "T[N]" → static size
                if (endsWith(t, "]")) {
                    int lb = strings::indexOf(t, '[');
                    if (lb >= 0) {
                        string size = substr(t, lb + 1, len(t) - 1);
                        return "((int64_t)" + size + ")";
                    }
                }
                return "(int64_t)strlen(" + argStrs.get(0) + ")";
            }
            return "0";
        }
        if (name == "substr") {
            return "glang_str_substr(" + strings::join(argStrs, ", ") + ")";
        }
        if (name == "startsWith") { return "glang_startswith(" + strings::join(argStrs, ", ") + ")"; }
        if (name == "endsWith")   { return "glang_endswith(" + strings::join(argStrs, ", ") + ")"; }
        if (name == "contains")   { return "glang_strcontains(" + strings::join(argStrs, ", ") + ")"; }
        if (name == "indexOf")    { return "glang_indexof_str(" + strings::join(argStrs, ", ") + ")"; }
        if (name == "parseInt")   { return "glang_parseint(" + strings::join(argStrs, ", ") + ")"; }
        if (name == "parseFloat") { return "glang_parsefloat(" + strings::join(argStrs, ", ") + ")"; }
        if (name == "intToStr")   { return "glang_inttostr(" + strings::join(argStrs, ", ") + ")"; }
        if (name == "readFile")   { return "glang_readfile(" + strings::join(argStrs, ", ") + ")"; }
        if (name == "writeFile")  { return "glang_writefile(" + strings::join(argStrs, ", ") + ")"; }
        if (name == "fileExists") { return "glang_fileexists(" + strings::join(argStrs, ", ") + ")"; }
        // Program args exclude the executable name (argv[0]), matching the
        // interpreter where getArg(0) is the first user-supplied argument.
        if (name == "getArgCount") { return "(int64_t)(glang_argc - 1)"; }
        if (name == "getArg") {
            if (argStrs.length() > 0) { return "glang_argv[(int)(" + argStrs.get(0) + ") + 1]"; }
            return "NULL";
        }
        if (name == "exit") {
            if (argStrs.length() > 0) { return "exit((int)(" + argStrs.get(0) + "))"; }
            return "exit(0)";
        }
        if (name == "readStdin")  { return "glang_readstdin()"; }

        // Constructor call written as ClassName() without 'new'
        if (this.info.isClass(name)) {
            return mangleName(name) + "_new(" + strings::join(argStrs, ", ") + ")";
        }

        // Normal function call
        string cname = mangleName(name);
        if (cname == "main") { cname = "glang_main"; }
        return cname + "(" + strings::join(argStrs, ", ") + ")";
    }

    string emitPrint(AstNode* e, List<string> argStrs, bool toErr) {
        string prefix = "glang_print_";
        if (toErr) { prefix = "glang_printerr_"; }
        if (argStrs.length() == 0) { return prefix + "string(\"\")"; }
        string arg = argStrs.get(0);
        string t = "int";
        if (e.numChildren() > 0) { t = this.typer.infer(e.child(0)); }
        if (t == "string") { return prefix + "string(" + arg + ")"; }
        if (t == "float")  { return prefix + "float(" + arg + ")"; }
        if (t == "bool")   { return prefix + "bool(" + arg + ")"; }
        if (t == "char")   { return prefix + "char(" + arg + ")"; }
        if (t == "int")    { return prefix + "int(" + arg + ")"; }
        if (t == "byte")   { return prefix + "int((int64_t)" + arg + ")"; }
        // Enum or other integer-like
        return prefix + "int((int64_t)" + arg + ")";
    }

    string emitIndirectCall(AstNode* e) {
        int numArgs = e.getInt("args");
        AstNode* callee = e.child(0);
        string calleeStr = this.emitExpr(callee);
        List<string> argStrs = List<string>();
        for (int i = 0; i < numArgs; ++i) {
            argStrs.add(this.emitExpr(e.child(1 + i)));
        }
        // Callee is a GlangFn value — call through it using a compound statement
        string calleeType = this.typer.infer(callee);
        if (startsWith(calleeType, "fn(")) {
            // Use GNU compound statement to avoid double-evaluation
            string tmpCall = emitGlangFnCall("__gfn__", calleeType, argStrs);
            return "({ GlangFn __gfn__ = " + calleeStr + "; " + tmpCall + "; })";
        }
        return calleeStr + "(" + strings::join(argStrs, ", ") + ")";
    }

    string emitMethodCall(AstNode* e) {
        string method = e.get("method");
        bool arrow    = e.getBool("arrow");
        int numArgs   = e.getInt("args");
        AstNode* obj  = e.child(0);
        string objStr = this.emitExpr(obj);
        string objType = this.typer.infer(obj);

        List<string> argStrs = List<string>();
        for (int i = 0; i < numArgs; ++i) {
            argStrs.add(this.emitExpr(e.child(1 + i)));
        }

        // Determine base type (strip pointer if already a pointer)
        string baseType = objType;
        bool isPtr = endsWith(objType, "*");
        if (isPtr) {
            baseType = substr(objType, 0, len(objType) - 1);
        }

        // In Glang, `.` is used even on pointer objects; in C we must pass the pointer.
        // Class-typed fields/vars are stored as pointers in C, so objStr is already a pointer.
        string selfArg = objStr;
        bool baseIsClass = this.info.isClass(baseType);
        if (!isPtr && !baseIsClass) {
            selfArg = "&" + objStr;
        }

        // Union variant construction: JsonValue.Number(42) → JsonValue__Number_new(42)
        if (this.info.isUnion(baseType)) {
            return mangleName(baseType) + "__" + method + "_new(" + strings::join(argStrs, ", ") + ")";
        }

        // Check modifier first
        if (this.info.hasModifier(baseType, method)) {
            string target = mangleName(baseType);
            string cname = target + "__" + mangleName(method);
            List<string> allArgs = List<string>();
            allArgs.add(selfArg);
            for (int i = 0; i < argStrs.length(); ++i) { allArgs.add(argStrs.get(i)); }
            return cname + "(" + strings::join(allArgs, ", ") + ")";
        }

        // Class method — walk super chain to find defining class
        string defCls = this.info.findMethodClass(baseType, method);
        string clsName = mangleName(defCls);
        string cname = clsName + "__" + mangleName(method);
        // If method is inherited and self needs to be cast to the defining class
        string castSelf = selfArg;
        if (defCls != baseType && isPtr) {
            castSelf = "((" + clsName + "*)" + selfArg + ")";
        }
        List<string> allArgs = List<string>();
        allArgs.add(castSelf);
        for (int i = 0; i < argStrs.length(); ++i) { allArgs.add(argStrs.get(i)); }
        return cname + "(" + strings::join(allArgs, ", ") + ")";
    }

    string emitNew(AstNode* e) {
        string cls    = e.get("cls");
        int numArgs   = e.getInt("args");
        string cname  = mangleName(cls) + "_new";

        // Check for union variant: "Dog.Puppy" style
        // After monomorphization, class_name is just the class name
        // Union new looks like: NewExpr with class_name="JsonValue.Number"
        if (contains(cls, ".")) {
            // Union variant heap allocation: new JsonValue.Number(99)
            int dot = indexOf(cls, ".");
            string uname = mangleName(substr(cls, 0, dot));
            string vname = substr(cls, dot + 1, len(cls));
            List<string> argStrs = List<string>();
            for (int i = 0; i < numArgs; ++i) {
                argStrs.add(this.emitExpr(e.child(i)));
            }
            string ctorCall = uname + "__" + vname + "_new(" + strings::join(argStrs, ", ") + ")";
            // Heap-allocate: return pointer via GCC compound statement
            return "({ " + uname + "* __up = (" + uname + "*)malloc(sizeof(" + uname + ")); *__up = " + ctorCall + "; __up; })";
        }

        List<string> argStrs = List<string>();
        for (int i = 0; i < numArgs; ++i) {
            argStrs.add(this.emitExpr(e.child(i)));
        }
        return cname + "(" + strings::join(argStrs, ", ") + ")";
    }

    string emitDelete(AstNode* e) {
        string operand = this.emitExpr(e.child(0));
        string t = this.typer.infer(e.child(0));
        string baseType = t;
        if (endsWith(t, "*")) { baseType = substr(t, 0, len(t) - 1); }
        // Unions are value types stored as heap pointers — just free
        if (this.info.isUnion(baseType)) { return "free(" + operand + ")"; }
        return mangleName(baseType) + "_delete(" + operand + ")";
    }

    string emitAlloc(AstNode* e) {
        string t = e.get("type");
        bool hasCount = e.getBool("has_count");
        if (hasCount && e.numChildren() > 0) {
            string count = this.emitExpr(e.child(0));
            return "(" + cTypeOf(t) + "*)calloc((size_t)(" + count + "), sizeof(" + cTypeOf(t) + "))";
        }
        return "(" + cTypeOf(t) + "*)malloc(sizeof(" + cTypeOf(t) + "))";
    }

    string emitClosure(AstNode* e) {
        int id = this.closureCounter;
        this.closureCounter = this.closureCounter + 1;
        string cid    = strings::intToStr(id);
        string capTypeName = "__cap_" + cid + "_t";
        string fnName  = "__closure_" + cid + "_fn";
        string ret    = this.cRetType(e.get("ret"));
        int numCaptures = e.getInt("captures");

        // Collect PARAMs, BINDs (captures), and BLOCK
        List<string> paramNames = List<string>();
        List<string> paramTypes = List<string>();
        List<string> bindNames  = List<string>();
        AstNode* body = null;
        for (int i = 0; i < e.numChildren(); ++i) {
            AstNode* ch = e.child(i);
            if (ch.tag == "PARAM") {
                paramNames.add(ch.get("name"));
                paramTypes.add(ch.get("type"));
            } else if (ch.tag == "BIND") {
                bindNames.add(ch.get("name"));
            } else if (ch.tag == "BLOCK") {
                body = ch;
            }
        }

        // Emit capture struct to preamble
        // Collect capture Glang types BEFORE pushing scope (uses outer scope)
        List<string> captureTypes = List<string>();
        for (int i = 0; i < bindNames.length(); ++i) {
            string btype = this.typer.lookup(bindNames.get(i));
            if (btype == "") { btype = "int"; }
            captureTypes.add(btype);
        }
        this.cdln("typedef struct {");
        for (int i = 0; i < bindNames.length(); ++i) {
            string cBtype = cTypeOf(captureTypes.get(i));
            this.cdln("    " + cBtype + " " + bindNames.get(i) + ";");
        }
        this.cdln("} " + capTypeName + ";");
        this.cdln("");

        // Emit closure function: takes void* cap + params
        StringBuilder fnParams = StringBuilder();
        fnParams.append("void* __cap__");
        for (int i = 0; i < paramNames.length(); ++i) {
            fnParams.append(", " + cTypeDecl(paramTypes.get(i), paramNames.get(i)));
        }
        this.cdln("static " + ret + " " + fnName + "(" + fnParams.build() + ") {");
        this.cdln("    " + capTypeName + "* c = (" + capTypeName + "*)__cap__;");

        // Use C macros so that any IDENT access to a capture expands to c->varname,
        // including mutations (c->varname = ... works transparently).
        for (int i = 0; i < bindNames.length(); ++i) {
            string bname = bindNames.get(i);
            this.cdln("#define " + bname + " (c->" + bname + ")");
        }

        // Push scope for closure body
        this.typer.pushScope();
        for (int i = 0; i < paramNames.length(); ++i) {
            this.typer.define(paramNames.get(i), cTypeOf(paramTypes.get(i)));
        }
        // Define captures in closure scope with their Glang types
        for (int i = 0; i < bindNames.length(); ++i) {
            this.typer.define(bindNames.get(i), captureTypes.get(i));
        }

        int savedIndent = this.indentLevel;
        this.indentLevel = 1;
        if (body != null) {
            for (int i = 0; i < body.numChildren(); ++i) {
                this.emitClosureStmt(body.child(i));
            }
        }
        this.indentLevel = savedIndent;

        this.typer.popScope();

        for (int i = 0; i < bindNames.length(); ++i) {
            this.cdln("#undef " + bindNames.get(i));
        }

        this.cdln("}");
        this.cdln("");

        // Build the GlangFn value: allocate cap struct and fill captures from outer scope
        StringBuilder capInit = StringBuilder();
        capInit.append("({ " + capTypeName + "* __cp__ = (" + capTypeName + "*)malloc(sizeof(" + capTypeName + ")); ");
        for (int i = 0; i < bindNames.length(); ++i) {
            string bname = bindNames.get(i);
            capInit.append("__cp__->" + bname + " = " + mangleName(bname) + "; ");
        }
        capInit.append("(GlangFn){ (void*)" + fnName + ", __cp__ }; })");

        return capInit.build();
    }

    // Emit a single statement to the closure defs (preamble) buffer.
    // Uses a simple approach: swap `out` to a temp builder, emit, swap back.
    void emitClosureStmt(AstNode* stmt) {
        // Save current output builder and redirect to closureDefs
        StringBuilder saved = this.out;
        this.out = this.closureDefs;
        this.emitStmt(stmt);
        this.out = saved;
    }

    // ── Parameter list helpers ───────────────────────────────────────────

    string buildParamList(AstNode* decl, string extraFirst) {
        StringBuilder sb = StringBuilder();
        bool first = true;
        if (extraFirst != "") {
            sb.append(extraFirst);
            first = false;
        }
        for (int i = 0; i < decl.numChildren(); ++i) {
            AstNode* ch = decl.child(i);
            if (ch.tag == "PARAM") {
                if (!first) { sb.append(", "); }
                string ptype = ch.get("type");
                // Class-typed parameters are passed as pointers in C
                if (this.info.isClass(ptype)) { ptype = ptype + "*"; }
                sb.append(cTypeDecl(ptype, ch.get("name")));
                first = false;
            }
        }
        if (first && extraFirst == "") { return "void"; }
        return sb.build();
    }

    string buildParamListWith(AstNode* decl, string extraFirst) {
        return this.buildParamList(decl, extraFirst);
    }

    // ── Utility ──────────────────────────────────────────────────────────

    AstNode* findChild(AstNode* node, string tag) {
        for (int i = 0; i < node.numChildren(); ++i) {
            AstNode* ch = node.child(i);
            if (ch.tag == tag) { return ch; }
        }
        return null;
    }

    // ── Assemble final output ────────────────────────────────────────────

    string build() {
        StringBuilder final = StringBuilder();
        final.appendLine("/* Generated by Glang transpiler */");
        final.appendLine("#include <inttypes.h>");
        final.appendLine("#include <stdio.h>");
        final.appendLine("#include <stdlib.h>");
        final.appendLine("#include <string.h>");
        final.appendLine("#include <stdint.h>");
        final.appendLine("#include <setjmp.h>");
        final.appendLine("#include <math.h>");
        final.appendLine("");
        final.appendLine("/* ── Closure / fn-pointer representation ───── */");
        final.appendLine("typedef struct { void* fn; void* cap; } GlangFn;");
        final.appendLine("");
        final.appendLine("/* ── Runtime declarations ───────────────────── */");
        final.appendLine("char* glang_str_concat(const char* a, const char* b);");
        final.appendLine("char* glang_str_substr(const char* s, int64_t start, int64_t end);");
        final.appendLine("int64_t glang_str_len(const char* s);");
        final.appendLine("int64_t glang_indexof_str(const char* s, const char* needle);");
        final.appendLine("int   glang_startswith(const char* s, const char* prefix);");
        final.appendLine("int   glang_endswith(const char* s, const char* suffix);");
        final.appendLine("int   glang_strcontains(const char* s, const char* needle);");
        final.appendLine("char* glang_inttostr(int64_t n);");
        final.appendLine("char* glang_floattostr(double f);");
        final.appendLine("char* glang_chartostr(char c);");
        final.appendLine("char* glang_booltostr(int b);");
        final.appendLine("int64_t glang_parseint(const char* s);");
        final.appendLine("double  glang_parsefloat(const char* s);");
        final.appendLine("char*   glang_readfile(const char* path);");
        final.appendLine("void    glang_writefile(const char* path, const char* content);");
        final.appendLine("int     glang_fileexists(const char* path);");
        final.appendLine("char*   glang_readstdin(void);");
        final.appendLine("void glang_print_int(int64_t v);");
        final.appendLine("void glang_print_float(double v);");
        final.appendLine("void glang_print_bool(int v);");
        final.appendLine("void glang_print_char(char v);");
        final.appendLine("void glang_print_string(const char* v);");
        final.appendLine("void glang_printerr_int(int64_t v);");
        final.appendLine("void glang_printerr_float(double v);");
        final.appendLine("void glang_printerr_bool(int v);");
        final.appendLine("void glang_printerr_char(char v);");
        final.appendLine("void glang_printerr_string(const char* v);");
        final.appendLine("char* glang_tostring_int(int64_t v);");
        final.appendLine("char* glang_tostring_float(double v);");
        final.appendLine("char* glang_tostring_bool(int v);");
        final.appendLine("char* glang_tostring_char(char v);");
        final.appendLine("char* glang_tostring_string(const char* v);");
        final.appendLine("extern int    glang_argc;");
        final.appendLine("extern char** glang_argv;");
        final.appendLine("");
        final.appendLine("typedef struct GlangExcFrame {");
        final.appendLine("    void* obj; const char* class_name;");
        final.appendLine("    jmp_buf env; struct GlangExcFrame* prev;");
        final.appendLine("} GlangExcFrame;");
        final.appendLine("extern GlangExcFrame* __glang_exc_top;");
        final.appendLine("void glang_throw(void* obj, const char* class_name);");
        final.appendLine("int  glang_instanceof(const char* actual, const char* target, const char** hier, int n);");
        final.appendLine("#define GLANG_TRY_BEGIN { GlangExcFrame __exc_frame__; __exc_frame__.obj=NULL; __exc_frame__.class_name=NULL; __exc_frame__.prev=__glang_exc_top; __glang_exc_top=&__exc_frame__; if(setjmp(__exc_frame__.env)==0) {");
        final.appendLine("#define GLANG_TRY_END   __glang_exc_top=__exc_frame__.prev; } else { __glang_exc_top=__exc_frame__.prev;");
        final.appendLine("#define GLANG_CATCH_DONE } }");
        final.appendLine("#define GLANG_THROW(o,c) glang_throw((void*)(o),(c))");
        final.appendLine("");

        // Forward typedefs
        final.append(this.preamble.build());
        final.appendLine("");

        // Enums must come before structs (struct fields may be enum-typed)
        final.appendLine("/* ── Enums ──────────────────────────────────── */");
        final.append(this.enums.build());

        // Structs / unions
        final.appendLine("/* ── Structs & unions ──────────────────────── */");
        final.append(this.structs.build());

        // Class hierarchy table for instanceof
        int hn = this.hierEntries.length();
        if (hn > 0) {
            final.appendLine("/* ── Class hierarchy ───────────────────────── */");
            final.append("static const char* __glang_hier__[] = {");
            for (int hi = 0; hi < hn; hi = hi + 2) {
                final.append(" \"" + this.hierEntries.get(hi) + "\", \"" + this.hierEntries.get(hi + 1) + "\",");
            }
            final.appendLine(" };");
            final.appendLine("static int __glang_hier_len__ = " + strings::intToStr(hn) + ";");
        } else {
            final.appendLine("static const char** __glang_hier__ = ((void*)0);");
            final.appendLine("static int __glang_hier_len__ = 0;");
        }
        final.appendLine("");

        // Static fields
        final.appendLine("/* ── Static fields ─────────────────────────── */");
        final.append(this.sfields.build());

        // Prototypes
        final.appendLine("/* ── Prototypes ────────────────────────────── */");
        final.append(this.protos.build());

        // Closure forward definitions
        if (len(this.closureDefs.build()) > 0) {
            final.appendLine("/* ── Closures ──────────────────────────────── */");
            final.append(this.closureDefs.build());
        }

        // Function bodies
        final.appendLine("/* ── Implementations ───────────────────────── */");
        final.append(this.out.build());

        return final.build();
    }
}

// ═══════════════════════════════════════════════════════════════════════════
// main
// ═══════════════════════════════════════════════════════════════════════════

int main() {
    if (getArgCount() < 2) {
        printErr("usage: transpiler <ast_file> <output.c>");
        return 1;
    }
    string astFile = getArg(0);
    string outFile = getArg(1);

    string content = readFile(astFile);
    if (len(content) == 0) {
        printErr("error: empty or missing AST file: " + astFile);
        return 1;
    }

    List<string> lines = strings::split(content, '\n');
    AstReader reader = AstReader(lines);

    // Read the root PROGRAM node
    AstNode* program = reader.readNode(0);
    if (program == null) {
        printErr("error: failed to read AST from " + astFile);
        return 1;
    }
    if (program.tag != "PROGRAM") {
        printErr("error: expected PROGRAM node, got: " + program.tag);
        return 1;
    }

    // Build global info
    GlobalInfo info = GlobalInfo();
    info.buildFrom(program);

    // Emit C
    CEmitter emitter = CEmitter(info);
    emitter.emitProgram(program);
    string cCode = emitter.build();

    writeFile(outFile, cCode);
    print("wrote " + outFile);
    return 0;
}
