# Frontend image from a PRE-BUILT bundle. The Vite build runs on the host (fast,
# native) producing learn/dist; this image just serves it with nginx. Used for
# cross-arch (amd64) builds so npm/vite never run under qemu emulation.
FROM nginx:alpine
COPY deploy/nginx.conf /etc/nginx/conf.d/default.conf
COPY learn/dist /usr/share/nginx/html
EXPOSE 80
