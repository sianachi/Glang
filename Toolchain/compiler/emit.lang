        f.appendLine("void glang_printerr_char(char v);");
        f.appendLine("void glang_printerr_string(const char* v);");
        f.appendLine("char* glang_tostring_int(int64_t v);");
        f.appendLine("char* glang_tostring_float(double v);");
        f.appendLine("char* glang_tostring_bool(int v);");
        f.appendLine("char* glang_tostring_char(char v);");
        f.appendLine("char* glang_tostring_string(const char* v);");
        f.appendLine("extern int    glang_argc;");
        f.appendLine("extern char** glang_argv;");
        f.appendLine("typedef struct GlangExcFrame {");
        f.appendLine("    void* obj; const char* class_name;");
        f.appendLine("    jmp_buf env; struct GlangExcFrame* prev;");
        f.appendLine("} GlangExcFrame;");
        f.appendLine("extern GlangExcFrame* __glang_exc_top;");
        f.appendLine("void glang_throw(void* obj, const char* class_name);");
        f.appendLine("int  glang_instanceof(const char* actual, const char* target, const char** hier, int n);");
        f.appendLine("#define GLANG_TRY_BEGIN { GlangExcFrame __exc_frame__; __exc_frame__.obj=NULL; __exc_frame__.class_name=NULL; __exc_frame__.prev=__glang_exc_top; __glang_exc_top=&__exc_frame__; if(setjmp(__exc_frame__.env)==0) {");
        f.appendLine("#define GLANG_TRY_END   __glang_exc_top=__exc_frame__.prev; } else { __glang_exc_top=__exc_frame__.prev;");
        f.appendLine("#define GLANG_CATCH_DONE } }");
        f.appendLine("#define GLANG_THROW(o,c) glang_throw((void*)(o),(c))");
        // class-hierarchy table for instanceof (flattened child,parent pairs)
        int hn = this.hierEntries.length();
        StringBuilder hier = StringBuilder();
        hier.append("static const char* __glang_hier__[] = { ");
        for (int i = 0; i < hn; ++i) { hier.append("\"" + this.hierEntries.get(i) + "\", "); }
        hier.append("0 };");
        f.appendLine(hier.build());
        f.appendLine("#define __glang_hier_len__ " + strings::intToStr(hn));
        f.appendLine("");
        f.append(this.preamble.build());
        f.append(this.enums.build());
        f.append(this.structs.build());
        f.append(this.protos.build());
        f.append(this.closureDefs.build());
        f.append(this.out.build());
        return f.build();
    }
}

// Entry point: typed Program + GlobalEnv → C source string.
string emit(Program* program, GlobalEnv* env) {
    CEmit em = CEmit(env);
    em.emitProgram(program);
    return em.build();
}
