// Demonstrates the three compiler-I/O builtins: getArgCount/getArg,
// printErr, and exit — with the arg-echo helper in a `cli` namespace,
// imported with a single-member `using` declaration.
// Run: python3 main.py run examples/compiler_io_demo.lang
// Run with args: python3 main.py run examples/compiler_io_demo.lang Alice

namespace cli {

// Print the first argument, then terminate immediately; code after the
// exit() call is never reached — not even in main.
void echoFirstArgAndExit() {
    print(getArg(0));
    exit(0);
}

}

using cli::echoFirstArgAndExit;

int main() {
    print(getArgCount());          // 0 when invoked with no extra args

    printErr("compiler_io_demo: stderr line");  // goes to stderr

    if (getArgCount() > 0) {
        echoFirstArgAndExit();
    }

    return 0;
}
