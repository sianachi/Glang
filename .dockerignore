# Keep the build context small and reproducible.
# NOTE: learn/dist is intentionally NOT ignored — the static frontend image
# (deploy/Dockerfile.frontend-static) copies the prebuilt bundle from it.
.git
**/node_modules
.venv
**/__pycache__
**/.pytest_cache
*.pyc

# Build artifacts (regenerated inside the image).
toolchain/glangc
toolchain/glangi
toolchain/*.o
toolchain/services/*.c
toolchain/services/run_server
toolchain/services/lsp_ws_server
toolchain/lsp/*.c
toolchain/lsp/glang-lsp
toolchain/services/*.out
**/*.gen.c
