// ---------------------------------------------------------------------------
// string modifier — treats string as a sequence of char
// ---------------------------------------------------------------------------

modifier for string {
    bool any(fn(char) -> bool predicate) {
        for (int i = 0; i < len(this); ++i) {
            if (predicate(this[i])) {
                return true;
            }
        }
        return false;
    }

    bool all(fn(char) -> bool predicate) {
        for (int i = 0; i < len(this); ++i) {
            if (!(predicate(this[i]))) {
                return false;
            }
        }
        return true;
    }

    int countWhere(fn(char) -> bool predicate) {
        int n = 0;
        for (int i = 0; i < len(this); ++i) {
            if (predicate(this[i])) {
                n = n + 1;
            }
        }
        return n;
    }

    char first(fn(char) -> bool predicate) {
        for (int i = 0; i < len(this); ++i) {
            if (predicate(this[i])) {
                return this[i];
            }
        }
        printErr("string.first: no character satisfies predicate");
        exit(1);
        return this[0];
    }

    void forEach(fn(char) -> void action) {
        for (int i = 0; i < len(this); ++i) {
            action(this[i]);
        }
    }

    // Returns matching characters as a List<char>. String concatenation with
    // a single char is not supported, so a filtered string cannot be built
    // directly; callers may join the result via stringFromBytes if needed.
    List<char> where(fn(char) -> bool predicate) {
        List<char> result = List<char>();
        for (int i = 0; i < len(this); ++i) {
            if (predicate(this[i])) {
                result.add(this[i]);
            }
        }
        return result;
    }
}

// ---------------------------------------------------------------------------
// Cross-type free functions (require a second type parameter)
// ---------------------------------------------------------------------------

List<U> select<T, U>(List<T> source, fn(T) -> U mapper) {
    List<U> result = List<U>();
    for (int i = 0; i < source.length(); ++i) {
        result.add(mapper(source.get(i)));
    }
    return result;
}

List<U> spanSelect<T, U>(Span<T> sp, fn(T) -> U mapper) {
    List<U> result = List<U>();
    for (int i = 0; i < sp.length(); ++i) {
        result.add(mapper(sp.get(i)));
    }
    return result;
}

T strReduce<T>(string s, fn(T, char) -> T reducer, T initial) {
    T acc = initial;
    for (int i = 0; i < len(s); ++i) {
        acc = reducer(acc, s[i]);
    }
    return acc;
}
