// std/linq.lang — LINQ-style operations via object modifiers.
//
// Importing this file extends List<T>, Span<T>, and string with query and
// iteration methods. Methods are added via the modifier system and are
// opt-in: importing std/list.lang alone does NOT provide them.
//
// Cross-type operations (select, spanSelect, strReduce) require a second
// type parameter and cannot be modifier methods; they remain free functions.

import "std/list.lang";

// ---------------------------------------------------------------------------
// List<T> modifier
// ---------------------------------------------------------------------------

modifier<T> for List<T> {
    List<T> where(fn(T) -> bool predicate) {
        List<T> result = List<T>();
        for (int i = 0; i < this.length(); ++i) {
            if (predicate(this.get(i))) {
                result.add(this.get(i));
            }
        }
        return result;
    }

    bool any(fn(T) -> bool predicate) {
        for (int i = 0; i < this.length(); ++i) {
            if (predicate(this.get(i))) {
                return true;
            }
        }
        return false;
    }

    bool all(fn(T) -> bool predicate) {
        for (int i = 0; i < this.length(); ++i) {
            if (!(predicate(this.get(i)))) {
                return false;
            }
        }
        return true;
    }

    int countWhere(fn(T) -> bool predicate) {
        int n = 0;
        for (int i = 0; i < this.length(); ++i) {
            if (predicate(this.get(i))) {
                n = n + 1;
            }
        }
        return n;
    }

    T first(fn(T) -> bool predicate) {
        for (int i = 0; i < this.length(); ++i) {
            if (predicate(this.get(i))) {
                return this.get(i);
            }
        }
        printErr("List.first: no element satisfies predicate");
        exit(1);
        return this.get(0);
    }

    void forEach(fn(T) -> void action) {
        for (int i = 0; i < this.length(); ++i) {
            action(this.get(i));
        }
    }

    T reduce(fn(T, T) -> T reducer, T initial) {
        T acc = initial;
        for (int i = 0; i < this.length(); ++i) {
            acc = reducer(acc, this.get(i));
        }
        return acc;
    }
}

