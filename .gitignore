# Byte-compiled / optimized files
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
env/
ENV/

# Test / coverage / type-checker caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/

# Packaging / build artifacts
build/
dist/
*.egg-info/
.eggs/

# Editors / IDEs
.idea/
*.swp
*.swo

# OS cruft
.DS_Store

# Scratch file written by examples/file_io.lang when run directly
glang_demo.txt

CLAUDE.md

AGENTS.md

plan.md

# Compiled C-extension / transpiler-generated artifacts (regenerated from sources).
# NOTE: glangc.c and runtime/*.c are intentionally NOT ignored — they are the
# bootstrap seed + runtime needed to build the compiler from scratch.
*.so
/analyser/*.c
/lexer/*.c
/parser/*.c
/errors/*.c
/glang_loader/*.c
/interpreter/*.c
/compiler/*.c

# Built program outputs (rebuild from sources)
/glangc
/mini_lexer
/mini_lexer.c
/console_io
/console_io.c

# Working / planning notes (not part of the shipped compiler)
/compiler/notes/
/compiler/SELFHOST.md
